<style>
  .mobile-hidden {
    display: none;
  }
  @media (min-width: 768px) {
    .mobile-hidden {
      display: block;
    }
  }
</style>

<script>
  const btn = document.getElementById("show-more-btn");
  const icon = document.getElementById("show-more-icon");
  const hiddenCards = document.querySelectorAll(".mobile-hidden");
  let expanded = false;

  btn?.addEventListener("click", () => {
    expanded = !expanded;

    hiddenCards.forEach((card) => {
      if (expanded) {
        card.classList.remove("mobile-hidden");
        card.classList.add("mobile-visible");
      } else {
        card.classList.add("mobile-hidden");
        card.classList.remove("mobile-visible");
      }
    });

    btn.innerHTML = expanded
      ? `Show Less <span style="display:inline-block; transform: rotate(180deg)">↓</span>`
      : `Show More <span>↓</span>`;
  });
</script>
