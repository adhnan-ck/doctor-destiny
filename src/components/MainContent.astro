---
import DestinationCard from "./DestinationCard.jsx";
import {
  ArrowRight,
  CheckCircle,
  GraduationCap,
  Globe,
  Users,
} from "lucide-react";
import HeroBanner from "./HeroBanner";
import WinningRecord from "./WinningRecord";
import ServiceCards from "./ServiceCards.jsx";
import WhyChooseUs from "./WhyChooseUs";
import OurProcess from "./OurProcess";
import TestimonialSection from "./TestimonialSection";
import WhoWeAre from "./WhoWeAre";

import tlImage from "../assets/countries/timor-leste.jpg";
import ruImage from "../assets/countries/russia.jpg";
import geImage from "../assets/countries/georgia.avif";
import inImage from "../assets/countries/india.jpg";
import euImage from "../assets/countries/europe.jpg";
import ukusaImage from "../assets/countries/uk-usa.jpg";
import deImage from "../assets/countries/germany.jpg";
import kgImage from "../assets/countries/krygystan.jpg";
import npImage from "../assets/countries/nepal.avif";
import cnImage from "../assets/countries/china.jpg";
import auImage from "../assets/countries/australia.jpg";
import kzImage from "../assets/countries/kazakhstan.jpg";
import uzImage from "../assets/countries/uzbekistan.jpg";
import bdImage from "../assets/countries/bangladesh.avif";
import muImage from "../assets/countries/mauritius.jpg";
import phImage from "../assets/countries/philippines.avif";
import ukUsa from "../assets/uk-and-usa.jpg";
import { Image } from "astro:assets";
import mdImg from "../assets/MD.png";
import groupDoctors from "../assets/group-doctors.jpg";
---

<div
  class="relative bg-[#F0F7FF] min-h-screen shadow-[0_-20px_60px_rgba(0,0,0,0.1)] border-t border-white/50"
>
  <!-- About Section -->
  <!-- About Section -->
  <section class="max-w-6xl mx-auto px-6 pt-24 pb-16">
    <div class="flex flex-col md:flex-row items-center gap-12 lg:gap-20">
      <!-- Left: Image -->
      <div class="flex-1 w-full">
        <div class="w-full aspect-[4/3] rounded-3xl overflow-hidden shadow-xl">
          <Image
            src={groupDoctors}
            alt="Top-Rated Consultant for MBBS Abroad"
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
      </div>

      <!-- Right: Text Content -->
      <div class="flex-1 text-left">
        <span
          class="inline-block py-1 px-3 rounded-full bg-[#D5AD36]/20 text-[#D5AD36] text-sm font-semibold mb-6 tracking-wide"
        >
          INDIA'S TOP CONSULTANT
        </span>
        <h2
          class="text-4xl md:text-5xl font-bold text-[#0E0C4F] mb-6 leading-tight"
        >
          Top-Rated Consultant for Study
          <span class="text-[#00BFFF]"> MBBS Abroad in India</span>
        </h2>
        <p class="text-xl text-gray-600 leading-relaxed mb-10">
          India's leading and most trusted consultants for MBBS abroad, guiding
          you to a successful medical career with expertise and transparency.
        </p>
      </div>
    </div>
  </section>

  <!-- Content + Form Section -->
  <section class="w-full bg-[#EBF2FA] py-16 px-6">
    <div
      class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center"
    >
      {/* Left Column: Content */}
      <div class="text-left md:pr-10">
        <h2
          class="text-4xl md:text-5xl font-bold text-[#0E0C4F] mb-6 leading-tight"
        >
          India's <span
            class="text-[#0E0C4F] underline decoration-[#D5AD36] decoration-4 underline-offset-4"
            >Leading and Most Trusted
          </span>
          Consultants for <br />
          <span class="text-[#00BFFF]"> MBBS Abroad.</span>
        </h2>

        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
          Achieve your dream of becoming a doctor with our Top-Rated MBBS Abroad
          Consultant services! We guide Indian students towards a successful
          medical career at prestigious universities across various major
          countries like Russia, Georgia, Philippines, and China, Kyrgyzstan.
          Our expert counsellors provide affordable and budget-friendly options,
          ensuring a smooth and stress-free journey to becoming a medical
          professional.
        </p>

        <!-- <div class="flex flex-col sm:flex-row gap-6 mt-8">
          <div class="flex items-center gap-4">
            <div class="bg-white p-3 rounded-full shadow-md text-[#D5AD36]">
              <CheckCircle size="32" />
            </div>
            <div>
              <p class="font-bold text-[#0E0C4F] text-lg">
                15+ Years Of Experience
              </p>
              <p class="text-gray-500 text-sm">
                Guidance and support to help you achieve your dream of becoming
                a doctor
              </p>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="bg-white p-3 rounded-full shadow-md text-[#D5AD36]">
              <GraduationCap size="32" />
            </div>
            <div>
              <p class="font-bold text-[#0E0C4F] text-lg">
                Award Winning Facilitators
              </p>
              <p class="text-gray-500 text-sm">
                Leading & Award Winning Facilitators For MBBS in Russia
              </p>
            </div>
          </div>
        </div> -->
      </div>

      {/* Right Column: Form Card */}
      <div
        class="bg-[#0E0C4F] p-8 md:p-10 rounded-3xl shadow-xl text-white relative overflow-hidden"
      >
        {/* Decorative background circle */}
        <div
          class="absolute -top-10 -right-10 w-32 h-32 bg-[#D5AD36] rounded-full opacity-20 blur-2xl pointer-events-none"
        >
        </div>

        <h3
          class="text-2xl md:text-3xl font-bold mb-6 text-center leading-snug"
        >
          Get Your <span class="text-[#00BFFF]">Blueprint</span> To <br /> MBBS Study
          Abroad
        </h3>

        <form
          id="callback-form"
          name="callback-requests"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-3 md:space-y-4"
        >
          <input type="hidden" name="form-name" value="callback-requests" />

          <p class="hidden" style="display:none;">
            <label>Don’t fill this out: <input name="bot-field" /></label>
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4">
            <input
              type="text"
              name="full-name"
              placeholder="Full Name"
              required
              class="w-full px-4 py-2.5 md:py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-gray-300 focus:outline-none focus:border-[#D5AD36] transition-colors"
            />
            <input
              type="tel"
              name="phone"
              placeholder="Phone Number"
              required
              class="w-full px-4 py-2.5 md:py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-gray-300 focus:outline-none focus:border-[#D5AD36] transition-colors"
            />
          </div>

          <input
            type="email"
            name="email"
            placeholder="Email Address"
            required
            class="w-full px-4 py-2.5 md:py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-gray-300 focus:outline-none focus:border-[#D5AD36] transition-colors"
          />

          <input
            type="text"
            name="location"
            placeholder="City / Address"
            class="w-full px-4 py-2.5 md:py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-gray-300 focus:outline-none focus:border-[#D5AD36] transition-colors"
          />

          <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4">
            <select
              name="course"
              required
              class="w-full px-4 py-2.5 md:py-3 rounded-xl bg-white/10 border border-white/20 text-white focus:outline-none focus:border-[#D5AD36] transition-colors appearance-none cursor-pointer"
            >
              <option value="" disabled selected class="text-gray-500"
                >Select Course</option
              >
              <option value="mbbs" class="text-black">MBBS</option>
              <option value="md-ms" class="text-black">MD-MS</option>
              <option value="ms" class="text-black">MS</option>
              <option value="bds" class="text-black">BDS</option>
              <option value="mds" class="text-black">MDS</option>
            </select>

            <select
              name="source"
              class="w-full px-4 py-2.5 md:py-3 rounded-xl bg-white/10 border border-white/20 text-white focus:outline-none focus:border-[#D5AD36] transition-colors appearance-none cursor-pointer"
            >
              <option value="" disabled selected class="text-gray-500"
                >How did you hear about us?</option
              >
              <option value="facebook" class="text-black">FaceBook</option>
              <option value="youtube" class="text-black">YouTube</option>
              <option value="instagram" class="text-black">Instagram</option>
              <option value="friends" class="text-black"
                >Friends & Family</option
              >
              <option value="others" class="text-black">Others</option>
            </select>
          </div>

          <div class="w-full">
            <input
              type="text"
              name="preferences"
              placeholder="Country Preference, College, Budget, Facility"
              class="w-full px-4 py-4 md:py-5 rounded-xl bg-white/10 border border-white/20 text-white placeholder-gray-300 focus:outline-none focus:border-[#D5AD36] transition-colors text-lg"
            />
          </div>

          <button
            type="submit"
            class="w-full bg-[#d5ad36] hover:bg-[#d62f3a] text-white font-bold py-4 rounded-xl shadow-lg transform hover:-translate-y-1 transition-all duration-300 mt-2 text-lg"
          >
            Request A Callback
          </button>
        </form>

        <!-- Success Dialog -->
        <dialog
          id="success-dialog"
          class="rounded-2xl shadow-2xl p-0 backdrop:bg-black/50 backdrop:backdrop-blur-sm border-0 bg-white m-auto fixed inset-0 z-50"
        >
          <div
            class="px-8 py-10 flex flex-col items-center text-center max-w-sm"
          >
            <div
              class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mb-6 text-green-500"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-8 w-8"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-[#0E0C4F] mb-3">
              Submission Successful!
            </h3>
            <p class="text-gray-600 mb-8">
              Thank you for reaching out to us! Our team will get back to you
              shortly with the blueprint to your MBBS journey.
            </p>
            <button
              type="button"
              id="close-dialog"
              class="w-full bg-[#0E0C4F] hover:bg-[#00BFFF] text-white font-bold py-3 px-6 rounded-xl transition-colors duration-300"
            >
              Close
            </button>
          </div>
        </dialog>
      </div>
    </div>
  </section>

  <!-- Who We Are Section -->
  <WhoWeAre />

  <!-- Destinations Grid (Bento Style) -->
  <section class="max-w-7xl mx-auto px-6 py-16">
    <div class="flex justify-between items-end mb-12">
      <h2 class="text-4xl md:text-5xl font-bold text-[#0E0C4F]">
        Top Countries for Study MBBS
      </h2>
    </div>
    <!-- Cards grid -->
    <div
      id="countries-grid"
      class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6"
    >
      {
        [
          {
            country: "Timor Leste",
            image: tlImage.src,
            flag: "tl",
            href: "/study-mbbs-in-timor-leste",
          },
          {
            country: "Russia",
            image: ruImage.src,
            flag: "ru",
            href: "/study-mbbs-in-russia",
          },
          {
            country: "Georgia",
            image: geImage.src,
            flag: "ge",
            href: "/study-mbbs-in-georgia",
          },
          {
            country: "India",
            image: inImage.src,
            flag: "in",
            href: "/study-mbbs-in-india",
          },
          {
            country: "Europe",
            image: euImage.src,
            flag: "eu",
            href: "/study-mbbs-in-europe",
          },
          {
            country: "UK and USA",
            image: ukusaImage.src,
            flag: ukUsa.src,
            href: "/study-mbbs-in-uk-and-usa",
          },
          {
            country: "Germany",
            image: deImage.src,
            flag: "de",
            href: "/study-mbbs-in-germany",
          },
          {
            country: "Kyrgyzstan",
            image: kgImage.src,
            flag: "kg",
            href: "/study-mbbs-in-kyrgyzstan",
          },
          {
            country: "Nepal",
            image: npImage.src,
            flag: "np",
            href: "/study-mbbs-in-nepal",
          },
          {
            country: "China",
            image: cnImage.src,
            flag: "cn",
            href: "/study-mbbs-in-china",
          },
          {
            country: "Australia",
            image: auImage.src,
            flag: "au",
            href: "/study-mbbs-in-australia",
          },
          {
            country: "Kazakhstan",
            image: kzImage.src,
            flag: "kz",
            href: "/study-mbbs-in-kazakhstan",
          },
          {
            country: "Uzbekistan",
            image: uzImage.src,
            flag: "uz",
            href: "/study-mbbs-in-uzbekistan",
          },
          {
            country: "Bangladesh",
            image: bdImage.src,
            flag: "bd",
            href: "/study-mbbs-in-bangladesh",
          },
          {
            country: "Mauritius",
            image: muImage.src,
            flag: "mu",
            href: "/study-mbbs-in-mauritius",
          },
          {
            country: "Philippines",
            image: phImage.src,
            flag: "ph",
            href: "/study-mbbs-in-philippines",
          },
        ].map((item, index) => (
          <div class={index >= 8 ? "mobile-hidden md:block" : ""}>
            <DestinationCard
              client:visible
              country={item.country}
              image={item.image}
              flag={item.flag}
              href={item.href}
            />
          </div>
        ))
      }
    </div>

    <!-- View More Button (Mobile Only) -->
    <div class="mt-12 flex justify-center md:hidden">
      <button
        id="show-more-btn"
        class="group bg-white border-2 border-[#0E0C4F] text-[#0E0C4F] px-8 py-3.5 rounded-2xl font-bold hover:bg-[#0E0C4F] hover:text-white transition-all duration-300 flex items-center gap-3 shadow-lg shadow-blue-900/5 active:scale-95"
      >
        <span>Show More Countries</span>
        <svg
          id="show-more-icon"
          class="w-5 h-5 transition-transform duration-300 group-hover:translate-y-0.5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M6 9l6 6 6-6"></path>
        </svg>
      </button>
    </div>
  </section>
</div>

<ServiceCards />
<WhyChooseUs />
<OurProcess />
<!-- <WinningRecord client:visible /> -->
<TestimonialSection client:visible />
<!-- Footer / Contact -->
<footer
  class="bg-[#0E0C4F] text-white pt-20 pb-10 rounded-t-[3rem]"
  style="position:relative; overflow:hidden;"
>
  <!-- MBBS-themed decorative background icons -->
  <div
    style="position:absolute;inset:0;pointer-events:none;z-index:0;overflow:hidden;"
    aria-hidden="true"
  >
    <!-- Stethoscope — top left -->
    <svg
      style="position:absolute;top:-10px;left:-20px;width:220px;height:220px;opacity:0.055;"
      viewBox="0 0 24 24"
      fill="none"
      stroke="white"
      stroke-width="0.8"
    >
      <path d="M4.5 2h3a1 1 0 0 1 1 1v5a4 4 0 0 1-8 0V3a1 1 0 0 1 1-1z"></path>
      <path d="M8 11a6 6 0 0 0 6 6 6 6 0 0 0 6-6v-1"></path>
      <circle cx="20" cy="10" r="2"></circle>
    </svg>

    <!-- Medical Cross — top center -->
    <svg
      style="position:absolute;top:20px;left:50%;transform:translateX(-50%);width:110px;height:110px;opacity:0.04;"
      viewBox="0 0 24 24"
      fill="white"
    >
      <rect x="9" y="2" width="6" height="20" rx="1.5"></rect>
      <rect x="2" y="9" width="20" height="6" rx="1.5"></rect>
    </svg>

    <!-- Globe — top right -->
    <svg
      style="position:absolute;top:-30px;right:-30px;width:240px;height:240px;opacity:0.055;"
      viewBox="0 0 24 24"
      fill="none"
      stroke="white"
      stroke-width="0.7"
    >
      <circle cx="12" cy="12" r="10"></circle>
      <ellipse cx="12" cy="12" rx="4" ry="10"></ellipse>
      <line x1="2" y1="12" x2="22" y2="12"></line>
      <line x1="12" y1="2" x2="12" y2="22"></line>
    </svg>

    <!-- Heartbeat / ECG line — mid left -->
    <svg
      style="position:absolute;top:40%;left:0;width:280px;height:80px;opacity:0.06;"
      viewBox="0 0 100 30"
      fill="none"
      stroke="white"
      stroke-width="1.2"
    >
      <polyline
        points="0,15 15,15 20,5 25,25 30,13 35,13 45,15 55,15 60,3 65,27 70,12 75,12 90,15 100,15"
      ></polyline>
    </svg>

    <!-- DNA double helix — mid right -->
    <svg
      style="position:absolute;top:30%;right:-10px;width:90px;height:180px;opacity:0.055;"
      viewBox="0 0 24 60"
      fill="none"
      stroke="white"
      stroke-width="0.9"
    >
      <path d="M4 2 Q12 10 20 18 Q12 26 4 34 Q12 42 20 50 Q12 58 4 66"></path>
      <path d="M20 2 Q12 10 4 18 Q12 26 20 34 Q12 42 4 50 Q12 58 20 66"></path>
      <line x1="8" y1="10" x2="16" y2="10"></line>
      <line x1="8" y1="26" x2="16" y2="26"></line>
      <line x1="8" y1="42" x2="16" y2="42"></line>
      <line x1="8" y1="58" x2="16" y2="58"></line>
    </svg>

    <!-- Graduation Cap — bottom left -->
    <svg
      style="position:absolute;bottom:-20px;left:8%;width:180px;height:180px;opacity:0.05;"
      viewBox="0 0 24 24"
      fill="none"
      stroke="white"
      stroke-width="0.8"
    >
      <path d="M22 10l-10-5-10 5 10 5 10-5z"></path>
      <path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"></path>
      <line x1="22" y1="10" x2="22" y2="16"></line>
    </svg>

    <!-- Pill capsule — bottom center-right -->
    <svg
      style="position:absolute;bottom:30px;right:25%;width:120px;height:60px;opacity:0.05;"
      viewBox="0 0 60 24"
      fill="none"
      stroke="white"
      stroke-width="1"
    >
      <rect x="2" y="8" width="56" height="8" rx="4"></rect>
      <line x1="30" y1="8" x2="30" y2="16"></line>
    </svg>

    <!-- Small scattered medical cross — bottom right -->
    <svg
      style="position:absolute;bottom:-10px;right:-10px;width:160px;height:160px;opacity:0.04;"
      viewBox="0 0 24 24"
      fill="white"
    >
      <rect x="9" y="2" width="6" height="20" rx="1"></rect>
      <rect x="2" y="9" width="20" height="6" rx="1"></rect>
    </svg>

    <!-- Tiny star/sparkle accents -->
    <svg
      style="position:absolute;top:22%;left:38%;width:18px;height:18px;opacity:0.1;"
      viewBox="0 0 24 24"
      fill="#D5AD36"
    >
      <polygon points="12,2 14,9 22,9 16,14 18,21 12,17 6,21 8,14 2,9 10,9"
      ></polygon>
    </svg>
    <svg
      style="position:absolute;top:60%;left:55%;width:14px;height:14px;opacity:0.09;"
      viewBox="0 0 24 24"
      fill="#D5AD36"
    >
      <polygon points="12,2 14,9 22,9 16,14 18,21 12,17 6,21 8,14 2,9 10,9"
      ></polygon>
    </svg>
    <svg
      style="position:absolute;top:12%;right:35%;width:16px;height:16px;opacity:0.08;"
      viewBox="0 0 24 24"
      fill="#D5AD36"
    >
      <polygon points="12,2 14,9 22,9 16,14 18,21 12,17 6,21 8,14 2,9 10,9"
      ></polygon>
    </svg>
  </div>

  <!-- Footer Content (above background icons) -->
  <div class="max-w-7xl mx-auto px-6" style="position:relative;z-index:1;">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      <div>
        <h3 class="text-2xl font-bold mb-6 text-[#D5AD36]">Doctor Destiny</h3>
        <p class="text-gray-300 leading-relaxed">
          Empowering aspiring doctors with the right guidance and opportunities
          to study medicine globally.
        </p>
      </div>

      <div>
        <h4 class="text-lg font-bold mb-6 text-[#D5AD36]">Quick Links</h4>
        <ul class="space-y-4 text-gray-300">
          <li>
            <a href="/about-us" class="hover:text-[#00BFFF] transition-colors"
              >About Us</a
            >
          </li>
          <!-- <li>
            <a href="#" class="hover:text-[#00BFFF] transition-colors"
              >MBBS in Georgia</a
            >
          </li> -->
          <li>
            <a href="#" class="hover:text-[#00BFFF] transition-colors"
              >Services</a
            >
          </li>
          <li>
            <a href="/contact-us" class="hover:text-[#00BFFF] transition-colors"
              >Contact</a
            >
          </li>
        </ul>
      </div>

      <div>
        <h4 class="text-lg font-bold mb-6 text-[#D5AD36]">Offices</h4>
        <p class="text-gray-300 mb-1 font-semibold">Ballary</p>
        <p class="text-gray-400 text-sm leading-relaxed">
          Nandi Arcade, 2nd Floor,<br />Opposite to Fire Station,<br />Infantry
          Road, BALLARY
        </p>
      </div>

      <div>
        <h4 class="text-lg font-bold mb-6 text-[#D5AD36]">Contact Us</h4>
        <p class="text-gray-300 mb-4">admissions@doctordestiny.com</p>
        <a
          href="/contact-us#contact-form"
          class="bg-gradient-to-r from-[#D5AD36] to-[#f0c847] hover:shadow-[0_0_20px_rgba(213,173,54,0.6)] text-[#0E0C4F] px-6 py-3 rounded-xl w-full font-semibold transition-all duration-300 hover:scale-105 block text-center"
        >
          Book Consultation
        </a>
      </div>
    </div>

    <div class="border-t border-white/10 pt-8 text-center text-gray-400">
      <p>&copy; 2026 Doctor Destiny. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .mobile-hidden {
    display: none;
  }
  @media (min-width: 768px) {
    .mobile-hidden {
      display: block;
    }
  }
</style>

<script>
  const btn = document.getElementById("show-more-btn");
  const btnText = btn?.querySelector("span");
  const icon = document.getElementById("show-more-icon");
  const hiddenCards = document.querySelectorAll(".mobile-hidden");
  let expanded = false;

  btn?.addEventListener("click", () => {
    expanded = !expanded;

    hiddenCards.forEach((card) => {
      if (expanded) {
        card.classList.remove("mobile-hidden");
        card.classList.add("mobile-visible");
      } else {
        card.classList.add("mobile-hidden");
        card.classList.remove("mobile-visible");
      }
    });

    if (btnText) {
      btnText.textContent = expanded ? "Show Less" : "Show More Countries";
    }

    if (icon) {
      icon.style.transform = expanded ? "rotate(180deg)" : "rotate(0deg)";
    }
  });

  // Form submission handler
  const callbackForm = document.getElementById("callback-form");
  const successDialog = document.getElementById("success-dialog");
  const closeDialogBtn = document.getElementById("close-dialog");

  if (callbackForm) {
    callbackForm.addEventListener("submit", async (e) => {
      e.preventDefault();

      const form = e.target as HTMLFormElement;
      const formData = new FormData(form);
      const submitBtn = form.querySelector(
        'button[type="submit"]',
      ) as HTMLButtonElement | null;

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerHTML =
          '<span class="animate-pulse">Submitting...</span>';
      }

      try {
        await fetch("/", {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          // @ts-ignore
          body: new URLSearchParams(formData as any).toString(),
        });

        form.reset();
        if (successDialog) {
          // @ts-ignore
          (successDialog as HTMLDialogElement).showModal();
        }
      } catch (error) {
        console.error("Form submission error:", error);
        alert("There was an error submitting the form. Please try again.");
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.innerHTML = "Request A Callback";
        }
      }
    });
  }

  if (closeDialogBtn && successDialog) {
    closeDialogBtn.addEventListener("click", () => {
      // @ts-ignore
      successDialog.close();
    });
  }
</script>
