---
import DestinationCard from "./DestinationCard.jsx";
import {
  ArrowRight,
  CheckCircle,
  GraduationCap,
  Globe,
  Users,
} from "lucide-react";
import HeroBanner from "./HeroBanner";
import WinningRecord from "./WinningRecord";
import ServiceCards from "./ServiceCards.jsx";
import WhyChooseUs from "./WhyChooseUs";
import OurProcess from "./OurProcess";
import TestimonialSection from "./TestimonialSection";
---

<div
  class="relative bg-[#F0F7FF] min-h-screen shadow-[0_-20px_60px_rgba(0,0,0,0.1)] border-t border-white/50"
>
  <!-- About Section -->
  <!-- <section class="max-w-6xl mx-auto px-6 pt-24 pb-16 text-center">
