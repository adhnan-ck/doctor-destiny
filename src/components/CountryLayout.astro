---
interface Props {
    countryName: string;
    navItems: { label: string; id: string }[];
    faqs: { question: string; answer: string }[];
}

const { countryName, navItems, faqs } = Astro.props;
---

<div class="bg-[#F0F7FF] min-h-screen">
    <!-- Three-Column Layout -->
    <div class="max-w-[1400px] mx-auto px-4 lg:px-6 py-10 lg:py-16">
        <div class="country-layout-grid">
            <!-- LEFT: Sticky Section Nav (desktop only) -->
            <aside class="desktop-sidebar">
                <nav
                    id="section-nav"
                    class="sticky top-24 self-start bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden"
                >
                    <div class="py-3">
                        {
                            navItems.map((item) => (
                                <a
                                    href={`#${item.id}`}
                                    class="nav-link block px-5 py-2.5 text-[13px] font-semibold text-gray-600 hover:bg-[#0E0C4F]/5 hover:text-[#0E0C4F] border-l-[3px] border-transparent transition-all duration-200"
                                    data-section={item.id}
                                >
                                    {item.label}
                                </a>
                            ))
                        }
                    </div>
                </nav>
            </aside>

            <!-- MIDDLE: Scrollable Content -->
            <main id="country-content" class="min-w-0">
                <slot />
            </main>

            <!-- RIGHT: Sticky Form (desktop only, below content on mobile) -->
            <aside class="desktop-sidebar">
                <div
                    class="sticky top-24 self-start bg-[#0E0C4F] p-7 rounded-2xl shadow-xl text-white relative overflow-hidden"
                >
                    <!-- Decorative background circle -->
                    <div
                        class="absolute -top-10 -right-10 w-32 h-32 bg-[#D5AD36] rounded-full opacity-20 blur-2xl pointer-events-none"
                    >
                    </div>

                    <h3 class="text-xl font-bold mb-5 text-center leading-snug">
                        Get Your <span class="text-[#00BFFF]">Blueprint</span> To
                        <br /> MBBS Study Abroad
                    </h3>

                    <form class="space-y-3">
                        <input
                            type="text"
                            placeholder="Name"
                            class="w-full px-4 py-2.5 rounded-xl bg-white/10 border border-white/20 text-white text-sm placeholder-gray-300 focus:outline-none focus:border-[#D5AD36] transition-colors"
                        />
                        <input
                            type="tel"
                            placeholder="Phone"
                            class="w-full px-4 py-2.5 rounded-xl bg-white/10 border border-white/20 text-white text-sm placeholder-gray-300 focus:outline-none focus:border-[#D5AD36] transition-colors"
                        />
                        <input
                            type="email"
                            placeholder="Email"
                            class="w-full px-4 py-2.5 rounded-xl bg-white/10 border border-white/20 text-white text-sm placeholder-gray-300 focus:outline-none focus:border-[#D5AD36] transition-colors"
                        />
                        <select
                            class="w-full px-4 py-2.5 rounded-xl bg-white/10 border border-white/20 text-white text-sm focus:outline-none focus:border-[#D5AD36] transition-colors appearance-none cursor-pointer"
                        >
                            <option
                                value=""
                                disabled
                                selected
                                class="text-gray-500">Courses</option
                            >
                            <option value="mbbs" class="text-black">MBBS</option
                            >
                            <option value="md-ms" class="text-black"
                                >MD-MS</option
                            >
                            <option value="ms" class="text-black">MS</option>
                            <option value="bds" class="text-black">BDS</option>
                            <option value="mds" class="text-black">MDS</option>
                        </select>
                        <input
                            type="text"
                            placeholder="Your NEET Score?"
                            class="w-full px-4 py-2.5 rounded-xl bg-white/10 border border-white/20 text-white text-sm placeholder-gray-300 focus:outline-none focus:border-[#D5AD36] transition-colors"
                        />
                        <input
                            type="text"
                            placeholder="Your MBBS Country Preference, College, Budget, Facility..."
                            class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white text-sm placeholder-gray-300 focus:outline-none focus:border-[#D5AD36] transition-colors"
                        />
                        <button
                            class="w-full bg-[#d5ad36] hover:bg-[#d62f3a] text-white font-bold py-3.5 rounded-xl shadow-lg transform hover:-translate-y-0.5 transition-all duration-300 mt-1 text-base"
                        >
                            Request a Callback
                        </button>
                    </form>
                </div>
            </aside>
        </div>

        <!-- Mobile Form (visible only on mobile) -->
        <div class="mobile-form">
            <div
                class="bg-[#0E0C4F] p-8 rounded-2xl shadow-xl text-white relative overflow-hidden"
            >
                <div
                    class="absolute -top-10 -right-10 w-32 h-32 bg-[#D5AD36] rounded-full opacity-20 blur-2xl pointer-events-none"
                >
                </div>
                <h3 class="text-2xl font-bold mb-5 text-center leading-snug">
                    Get Your <span class="text-[#00BFFF]">Blueprint</span> To <br
                    /> MBBS Study Abroad
                </h3>
                <form class="space-y-3">
                    <input
                        type="text"
                        placeholder="Name"
                        class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-gray-300 focus:outline-none focus:border-[#D5AD36] transition-colors"
                    />
                    <input
                        type="tel"
                        placeholder="Phone"
                        class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-gray-300 focus:outline-none focus:border-[#D5AD36] transition-colors"
                    />
                    <input
                        type="email"
                        placeholder="Email"
                        class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-gray-300 focus:outline-none focus:border-[#D5AD36] transition-colors"
                    />
                    <select
                        class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white focus:outline-none focus:border-[#D5AD36] transition-colors appearance-none cursor-pointer"
                    >
                        <option value="" disabled selected class="text-gray-500"
                            >Courses</option
                        >
                        <option value="mbbs" class="text-black">MBBS</option>
                        <option value="md-ms" class="text-black">MD-MS</option>
                        <option value="ms" class="text-black">MS</option>
                        <option value="bds" class="text-black">BDS</option>
                        <option value="mds" class="text-black">MDS</option>
                    </select>
                    <input
                        type="text"
                        placeholder="Your NEET Score?"
                        class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-gray-300 focus:outline-none focus:border-[#D5AD36] transition-colors"
                    />
                    <input
                        type="text"
                        placeholder="Your MBBS Country Preference, College, Budget, Facility..."
                        class="w-full px-4 py-3.5 rounded-xl bg-white/10 border border-white/20 text-white placeholder-gray-300 focus:outline-none focus:border-[#D5AD36] transition-colors"
                    />
                    <button
                        class="w-full bg-[#d5ad36] hover:bg-[#d62f3a] text-white font-bold py-4 rounded-xl shadow-lg transform hover:-translate-y-1 transition-all duration-300 mt-1 text-lg"
                    >
                        Request a Callback
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- FAQ Section -->
    {
        faqs && faqs.length > 0 && (
            <section class="max-w-4xl mx-auto px-6 pb-20">
                <h2 class="text-4xl md:text-5xl font-bold text-[#0E0C4F] text-center mb-12">
                    Frequently Asked{" "}
                    <span class="text-[#00BFFF]">Questions</span>
                </h2>
                <div class="space-y-4" id="faq-container">
                    {faqs.map((faq, i) => (
                        <details class="faq-item group bg-white rounded-2xl shadow-md border border-gray-100 overflow-hidden transition-all duration-300 hover:shadow-lg">
                            <summary class="flex items-center justify-between cursor-pointer px-6 py-5 text-[#0E0C4F] font-semibold text-base md:text-lg select-none list-none">
                                <span>{faq.question}</span>
                                <svg
                                    width="20"
                                    height="20"
                                    class="text-[#00BFFF] transform transition-transform duration-300 group-open:rotate-180 shrink-0 ml-4"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M19 9l-7 7-7-7"
                                    />
                                </svg>
                            </summary>
                            <div class="px-6 pb-5 text-gray-600 leading-relaxed text-[15px] border-t border-gray-100 pt-4">
                                <Fragment set:html={faq.answer} />
                            </div>
                        </details>
                    ))}
                </div>
            </section>
        )
    }
</div>

<style>
    .country-layout-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    .desktop-sidebar {
        display: none;
    }

    .mobile-form {
        display: block;
        margin-top: 3rem;
    }

    @media (min-width: 1024px) {
        .country-layout-grid {
            grid-template-columns: 220px 1fr 300px;
            gap: 1.75rem;
            align-items: stretch; /* Change from start to stretch, or remove this line */
        }

        .desktop-sidebar {
            display: block;
            height: 100%; /* Ensure the aside takes up the full grid column height */
        }

        .mobile-form {
            display: none;
        }
    }

    /* Active nav link highlight */
    .nav-link.active {
        color: #0e0c4f;
        background-color: rgba(14, 12, 79, 0.06);
        border-left-color: #00bfff;
    }

    /* Remove default details marker */
    details summary::-webkit-details-marker {
        display: none;
    }

    /* Smooth FAQ open animation */
    details[open] > div {
        animation: fadeIn 0.25s ease-out;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-4px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<script>
    // Intersection Observer for active nav highlight
    const sections = document.querySelectorAll("#country-content section[id]");
    const navLinks = document.querySelectorAll("#section-nav .nav-link");

    if (sections.length && navLinks.length) {
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        navLinks.forEach((link) =>
                            link.classList.remove("active"),
                        );
                        const activeLink = document.querySelector(
                            `#section-nav .nav-link[data-section="${entry.target.id}"]`,
                        );
                        activeLink?.classList.add("active");
                    }
                });
            },
            {
                rootMargin: "-100px 0px -60% 0px",
                threshold: 0,
            },
        );

        sections.forEach((section) => observer.observe(section));
    }

    // Smooth scroll for nav links
    document.querySelectorAll("#section-nav .nav-link").forEach((link) => {
        link.addEventListener("click", (e) => {
            e.preventDefault();
            const targetId = (
                e.currentTarget as HTMLAnchorElement
            ).getAttribute("data-section");
            const target = document.getElementById(targetId!);
            if (target) {
                target.scrollIntoView({ behavior: "smooth", block: "start" });
            }
        });
    });
</script>
