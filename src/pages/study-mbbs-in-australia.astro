---
import "../styles/global.css";
import "flag-icons/css/flag-icons.min.css";
import Navbar from "../components/Navbar.jsx";
import CountryLayout from "../components/CountryLayout.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&display=swap"
            rel="stylesheet"
        />
        <meta
            name="description"
            content="Study MBBS in Australia – Comprehensive guide to top medical universities, fees, eligibility, and admission processes for international students in 2024."
        />
        <title>Study MBBS in Australia: Top Universities, Fees & Admissions | Doctor Destiny</title>
    </head>
    <body class="bg-[#F0F7FF] overflow-x-hidden">
        <Navbar client:load />

        <!-- Page Hero -->
        <div class="bg-[#0E0C4F] pt-28 pb-16 px-6">
            <div class="max-w-5xl mx-auto text-center">
                <span
                    class="inline-block py-1 px-4 rounded-full bg-white/10 text-[#D5AD36] text-sm font-bold mb-4 tracking-widest uppercase"
                >
                    Study Abroad
                </span>
                <h1
                    class="text-4xl md:text-6xl font-extrabold text-white leading-tight mb-4"
                >
                    Study MBBS in <span class="text-[#00BFFF]">Australia</span>
                </h1>
                <p
                    class="text-lg text-gray-300 max-w-3xl mx-auto leading-relaxed"
                >
                    Pursue your medical dream in a country renowned for global standards, world-class research facilities, and high clinical exposure. Explore premium education pathways across top-ranked Australian universities.
                </p>
                <div class="mt-8">
                    <button class="bg-gradient-to-r from-[#D5AD36] to-[#f0c847] hover:shadow-[0_0_20px_rgba(213,173,54,0.6)] text-[#0E0C4F] px-8 py-3 rounded-full font-bold transition-all duration-300 hover:scale-105">
                        Enroll Now
                    </button>
                </div>
            </div>
        </div>

        <!-- Country Layout (3-column) -->
        <CountryLayout
            countryName="Australia"
            navItems={[
                { label: "Overview & Duration", id: "overview" },
                { label: "Pathways", id: "pathways" },
                { label: "Eligibility", id: "eligibility" },
                { label: "Top Universities", id: "universities" },
                { label: "Fee Structure", id: "fees" },
                { label: "Admission Process", id: "process" },
            ]}
            faqs={[
                {
                    question: "Is Australian MBBS completely recognized in India?",
                    answer: "Yes, degrees granted by the Medical Board of Australia are widely accepted globally, including by the National Medical Commission (NMC) in India.",
                },
                {
                    question: "Do I need to take the UCAT exam?",
                    answer: "Yes, most universities require international students to take the UCAT (University Clinical Aptitude Test) or ISAT for undergraduate pathways, and GAMSAT/MCAT for graduate entry.",
                },
                {
                    question: "Can I practice in Australia after graduation?",
                    answer: "Yes, upon completing your degree and the mandatory 1-year internship, you can register and practice medicine in Australia.",
                },
                {
                    question: "Are there scholarships available for Indian students?",
                    answer: "There are limited merit-based scholarships available for international students, but studying in Australia generally requires proof of significant personal or loan funding.",
                }
            ]}
        >
            <!-- SECTION: Overview -->
            <section id="overview" class="mb-12 scroll-mt-24">
                <h2 class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30">
                    Overview & Course Duration
                </h2>
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 mb-6">
                    <p class="text-gray-700 leading-relaxed">
                        Australia is a globally dominant destination for medical education, offering state-of-the-art infrastructure. However, it is a highly competitive and premium investment, requiring top-tier academic performance and aptitude scores to secure a seat.
                    </p>
                </div>
                
                <h3 class="text-xl font-bold text-[#0E0C4F] mb-4">Course Duration Variances</h3>
                <div class="grid md:grid-cols-2 gap-6">
                    <div class="border border-blue-100 bg-blue-50/30 p-5 rounded-xl">
                        <h4 class="font-bold text-[#00BFFF] mb-2 flex items-center gap-2">
                           <span class="text-xl">🎓</span> Undergraduate Entry
                        </h4>
                        <p class="text-gray-700 font-bold mb-1">5 to 6 Years</p>
                        <p class="text-sm text-gray-600">Directly after 12th standard completion. (MBBS or BMedSci+MD)</p>
                    </div>
                    <div class="border border-indigo-100 bg-indigo-50/30 p-5 rounded-xl">
                        <h4 class="font-bold text-[#0E0C4F] mb-2 flex items-center gap-2">
                           <span class="text-xl">🎓</span> Graduate Entry
                        </h4>
                        <p class="text-gray-700 font-bold mb-1">4 Years</p>
                        <p class="text-sm text-gray-600">For students who already hold a relevant Bachelor's degree. (MD program)</p>
                    </div>
                </div>
            </section>

             <!-- SECTION: Pathways -->
            <section id="pathways" class="mb-12 scroll-mt-24">
                 <h2 class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30">
                    Medical Pathways Explained
                </h2>
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="p-6">
                       <ul class="space-y-6">
                           <li class="flex gap-4 items-start">
                               <div class="w-12 h-12 rounded-full bg-blue-100 text-[#00BFFF] flex items-center justify-center font-bold text-xl shrink-0">1</div>
                               <div>
                                   <h4 class="font-bold text-[#0E0C4F] text-lg">Undergraduate Medical Program (Standard)</h4>
                                   <p class="text-gray-600 mt-2 text-sm leading-relaxed">Typically a 5 or 6-year program directly after high school. Students earn a Bachelor of Medicine, Bachelor of Surgery (MBBS), or increasingly, a joint Bachelor degree combined directly with a Doctor of Medicine (MD) master's level degree.</p>
                                    <div class="mt-3 inline-block bg-gray-100 px-3 py-1 rounded text-xs font-semibold text-gray-600">Tests: UCAT ANZ or ISAT</div>
                               </div>
                           </li>
                           <li class="flex gap-4 items-start">
                               <div class="w-12 h-12 rounded-full bg-yellow-100 text-[#D5AD36] flex items-center justify-center font-bold text-xl shrink-0">2</div>
                               <div>
                                   <h4 class="font-bold text-[#0E0C4F] text-lg">Graduate Entry Doctor of Medicine (MD)</h4>
                                   <p class="text-gray-600 mt-2 text-sm leading-relaxed">A 4-year accelerated program designed for students who have already completed an undergraduate degree (often in Biomedical Sciences or similar fields) either in Australia or their home country.</p>
                                   <div class="mt-3 inline-block bg-gray-100 px-3 py-1 rounded text-xs font-semibold text-gray-600">Tests: GAMSAT or MCAT</div>
                               </div>
                           </li>
                       </ul>
                    </div>
                </div>
            </section>

            <!-- SECTION: Eligibility -->
            <section id="eligibility" class="mb-12 scroll-mt-24">
                <h2 class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30">
                    Eligibility Criteria (2024-25)
                </h2>
                <div class="grid md:grid-cols-2 gap-4">
                    <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
                        <div class="text-[#00BFFF] mb-2">⭐</div>
                        <h4 class="font-bold text-[#0E0C4F] mb-1">Academic Score</h4>
                        <p class="text-sm text-gray-600">Extremely high cutoffs. Usually 85% to 95%+ in 12th standard (Physics, Chemistry, Biology) equivalent to an ATAR of 90-99.</p>
                    </div>
                    <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
                        <div class="text-[#00BFFF] mb-2">🗣️</div>
                        <h4 class="font-bold text-[#0E0C4F] mb-1">English Proficiency</h4>
                        <p class="text-sm text-gray-600">Mandatory high scores in IELTS (min 6.5-7.0 overall, no band less than 6.5) or TOEFL iBT (min 90+).</p>
                    </div>
                    <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
                        <div class="text-[#00BFFF] mb-2">📝</div>
                        <h4 class="font-bold text-[#0E0C4F] mb-1">Entrance Exams</h4>
                        <p class="text-sm text-gray-600">A valid <strong class="text-[#0E0C4F]">NEET</strong> scorecard (for Indians), plus <strong class="text-[#0E0C4F]">UCAT/ISAT</strong> for Undergrad, or <strong class="text-[#0E0C4F]">GAMSAT/MCAT</strong> for Grad Entry.</p>
                    </div>
                    <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
                        <div class="text-[#00BFFF] mb-2">🎂</div>
                        <h4 class="font-bold text-[#0E0C4F] mb-1">Age Requirement</h4>
                        <p class="text-sm text-gray-600">Minimum 17 years of age by December 31st of the admission year.</p>
                    </div>
                </div>
            </section>

            <!-- SECTION: Universities -->
            <section id="universities" class="mb-12 scroll-mt-24">
                <h2 class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30">
                    Top Medical Universities in Australia
                </h2>
                <p class="text-gray-600 mb-6 text-sm">Australian universities consistently rank in the QS World Top 100 for medical and clinical programs.</p>

                <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
                    <table class="w-full text-left border-collapse min-w-[600px]">
                        <thead>
                            <tr class="bg-[#0E0C4F] text-white text-sm">
                                <th class="px-4 py-3 font-semibold">University Name</th>
                                <th class="px-4 py-3 font-semibold">Location</th>
                                <th class="px-4 py-3 font-semibold">QS World Rank (Approx)</th>
                            </tr>
                        </thead>
                        <tbody class="text-gray-700 text-sm">
                            <tr class="border-b bg-white">
                                <td class="px-4 py-3 font-bold text-[#0E0C4F]">University of Melbourne</td>
                                <td class="px-4 py-3">Melbourne, VIC</td>
                                <td class="px-4 py-3 font-bold text-[#00BFFF]">#14</td>
                            </tr>
                            <tr class="border-b bg-gray-50/50">
                                <td class="px-4 py-3 font-bold text-[#0E0C4F]">University of Sydney</td>
                                <td class="px-4 py-3">Sydney, NSW</td>
                                <td class="px-4 py-3 font-bold text-[#00BFFF]">#19</td>
                            </tr>
                            <tr class="border-b bg-white">
                                <td class="px-4 py-3 font-bold text-[#0E0C4F]">Monash University</td>
                                <td class="px-4 py-3">Melbourne, VIC</td>
                                <td class="px-4 py-3 font-bold text-[#00BFFF]">#42</td>
                            </tr>
                            <tr class="border-b bg-gray-50/50">
                                <td class="px-4 py-3 font-bold text-[#0E0C4F]">University of Queensland</td>
                                <td class="px-4 py-3">Brisbane, QLD</td>
                                <td class="px-4 py-3 font-bold text-[#00BFFF]">#43</td>
                            </tr>
                            <tr class="border-b bg-white">
                                <td class="px-4 py-3 font-bold text-[#0E0C4F]">University of New South Wales (UNSW)</td>
                                <td class="px-4 py-3">Sydney, NSW</td>
                                <td class="px-4 py-3 font-bold text-[#00BFFF]">#45</td>
                            </tr>
                            <tr class="border-b bg-gray-50/50">
                                <td class="px-4 py-3 font-bold text-[#0E0C4F]">Australian National University (ANU)</td>
                                <td class="px-4 py-3">Canberra, ACT</td>
                                <td class="px-4 py-3 font-bold text-[#00BFFF]">#34</td>
                            </tr>
                            <tr class="bg-white">
                                <td class="px-4 py-3 font-bold text-[#0E0C4F]">University of Adelaide</td>
                                <td class="px-4 py-3">Adelaide, SA</td>
                                <td class="px-4 py-3 font-bold text-[#00BFFF]">#89</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- SECTION: Fees -->
            <section id="fees" class="mb-12 scroll-mt-24">
                <h2 class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30">
                    Fee Structure & Cost of Living
                </h2>
                <div class="bg-[#0E0C4F] p-6 rounded-2xl text-white mb-6">
                    <h3 class="text-xl font-bold mb-4 text-[#D5AD36]">Estimated Annual Tuition Fees</h3>
                    <div class="flex items-center gap-4 bg-white/10 p-4 rounded-xl border border-white/20">
                        <span class="text-3xl">💰</span>
                        <div>
                            <p class="text-2xl font-black text-white">AUD 55,000 to AUD 90,000 <span class="text-sm font-normal text-gray-300">/ Year</span></p>
                            <p class="text-sm text-gray-300 mt-1">(Approx. ₹30 Lakhs to ₹50 Lakhs per year)</p>
                        </div>
                    </div>
                </div>

                <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm">
                    <h3 class="text-lg font-bold text-[#0E0C4F] mb-3">Living Expenses</h3>
                    <p class="text-gray-600 mb-4 text-sm leading-relaxed">
                        International students need roughly <strong>AUD 20,000 to AUD 30,000 per year</strong> (~₹10.5 Lakhs to ₹16 Lakhs) to cover living costs, including accommodation, food, utilities, and transportation.
                    </p>
                    <div class="bg-yellow-50 p-4 rounded-lg flex gap-3 text-sm text-yellow-800 border border-yellow-200">
                        <span class="font-bold text-lg">!</span>
                        <p>Proof of adequate funds is a strict requirement for the Subclass 500 Student Visa processing.</p>
                    </div>
                </div>
            </section>

             <!-- SECTION: Process -->
            <section id="process" class="mb-12 scroll-mt-24">
                <h2 class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30">
                    Admission Process
                </h2>
                <div class="space-y-4">
                    <div class="flex gap-4 items-start p-5 bg-white rounded-xl shadow-sm border border-gray-100">
                        <span class="flex-shrink-0 w-10 h-10 rounded-full bg-[#0E0C4F] text-white flex items-center justify-center font-bold text-sm">1</span>
                        <div>
                            <h4 class="font-bold text-[#0E0C4F]">Aptitude Testing</h4>
                            <p class="text-sm text-gray-600 mt-1">Register for and clear the required aptitude test (UCAT ANZ/ISAT for Undergrad) well before the university application deadlines.</p>
                        </div>
                    </div>
                    <div class="flex gap-4 items-start p-5 bg-white rounded-xl shadow-sm border border-gray-100">
                        <span class="flex-shrink-0 w-10 h-10 rounded-full bg-[#0E0C4F] text-white flex items-center justify-center font-bold text-sm">2</span>
                        <div>
                            <h4 class="font-bold text-[#0E0C4F]">University Applications</h4>
                            <p class="text-sm text-gray-600 mt-1">Choose your preferred universities and submit direct applications, providing academic transcripts, IELTS/TOEFL scores, and Statement of Purpose (SOP).</p>
                        </div>
                    </div>
                    <div class="flex gap-4 items-start p-5 bg-white rounded-xl shadow-sm border border-gray-100">
                        <span class="flex-shrink-0 w-10 h-10 rounded-full bg-[#0E0C4F] text-white flex items-center justify-center font-bold text-sm">3</span>
                        <div>
                            <h4 class="font-bold text-[#0E0C4F]">Multiple Mini Interviews (MMI)</h4>
                            <p class="text-sm text-gray-600 mt-1">Shortlisted candidates must clear the university's MMI (Interviews) which test communication, ethics, and emotional intelligence.</p>
                        </div>
                    </div>
                    <div class="flex gap-4 items-start p-5 bg-white rounded-xl shadow-sm border border-gray-100">
                        <span class="flex-shrink-0 w-10 h-10 rounded-full bg-[#D5AD36] text-white flex items-center justify-center font-bold text-sm">4</span>
                        <div>
                            <h4 class="font-bold text-[#0E0C4F]">Offer & Visa (Subclass 500)</h4>
                            <p class="text-sm text-gray-600 mt-1">Accept the final offer letter, complete fee payments, purchase Overseas Student Health Cover (OSHC), and apply for the Australian Student Visa.</p>
                        </div>
                    </div>
                </div>
            </section>

        </CountryLayout>

        <Footer />
    </body>
</html>
