---
import "../styles/global.css";
import Navbar from "../components/Navbar";
import Footer from "../components/Footer.astro";
import { Image } from "astro:assets";
import mdImg from "../assets/MD.png";
import founder2Img from "../assets/founder_2.jpeg";
import doctorAboutImg from "../assets/doctor-image-aboutus.png";
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>About Us – Doctor Destiny</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600&display=swap"
            rel="stylesheet"
        />
        <style>
            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            :root {
                --navy: #0e0c4f;
                --sky: #00bfff;
                --gold: #d5ad36;
                --gray: #6b7280;
                --light: #f8fafc;
            }

            body {
                font-family: "Inter", sans-serif;
                color: #1f2937;
                background: #fff;
                overflow-x: hidden;
            }

            h1,
            h2,
            h3,
            h4 {
                font-family: "Playfair Display", serif;
            }

            .badge {
                display: inline-block;
                padding: 4px 14px;
                border-radius: 999px;
                background: rgba(213, 173, 54, 0.15);
                color: var(--gold);
                font-size: 0.75rem;
                font-weight: 700;
                letter-spacing: 0.08em;
                font-family: "Inter", sans-serif;
                margin-bottom: 1.25rem;
            }

            /* ── SECTION 1: FOUNDER ── */
            .founder-section {
                background: var(--light);
                padding: 96px 24px;
            }

            .founder-inner {
                max-width: 1200px;
                margin: 0 auto;
                display: grid;
                grid-template-columns: 1fr 1.15fr;
                gap: 80px;
                align-items: center;
            }

            .founder-image-wrap {
                position: relative;
                max-width: 480px;
                width: 100%;
                margin: 0 auto;
            }

            .founder-image-placeholder {
                width: 100%;
                aspect-ratio: 3/4;
                border-radius: 24px;
                background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
                border: 1px solid rgba(0, 191, 255, 0.1);
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: flex-end;
                position: relative;
                overflow: hidden;
                padding: 20px;
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
            }

            .placeholder-bg-icons {
                position: absolute;
                inset: 0;
                z-index: 0;
                opacity: 0.4;
                pointer-events: none;
            }

            .placeholder-bg-icons svg {
                position: absolute;
                color: rgba(0, 191, 255, 0.15);
                fill: currentColor;
            }

            .founder-image-placeholder :global(img) {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                object-fit: cover;
                z-index: 1;
            }

            .founder-accent {
                position: absolute;
                width: 120px;
                height: 120px;
                border-radius: 50%;
                background: rgba(0, 191, 255, 0.12);
                top: -24px;
                left: -24px;
                z-index: 0;
            }

            .founder-accent-2 {
                position: absolute;
                width: 80px;
                height: 80px;
                border-radius: 50%;
                background: rgba(213, 173, 54, 0.15);
                bottom: -20px;
                right: -20px;
                z-index: 0;
            }

            .founder-content h2 {
                font-size: 2.6rem;
                color: var(--navy);
                line-height: 1.2;
                margin-bottom: 1.5rem;
            }
            .founder-content h2 span {
                color: var(--sky);
            }
            .founder-content p {
                font-size: 1.05rem;
                color: var(--gray);
                line-height: 1.85;
            }

            .founder-name-card {
                position: relative;
                z-index: 2;
                display: flex;
                align-items: center;
                gap: 14px;
                padding: 12px 16px;
                background: rgba(255, 255, 255, 0.9);
                backdrop-filter: blur(10px);
                border-radius: 12px;
                box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
                border-left: 4px solid var(--sky);
                width: 100%;
            }

            .founder-name-card strong {
                display: block;
                font-size: 1rem;
                color: var(--navy);
                font-family: "Playfair Display", serif;
            }
            .founder-name-card span {
                font-size: 0.8rem;
                color: var(--gray);
            }

            /* ── SECTION 1b: SECOND FOUNDER (reversed) ── */
            .founder-section-alt {
                background: #fff;
                padding: 96px 24px;
            }

            .founder-inner-alt {
                max-width: 1200px;
                margin: 0 auto;
                display: grid;
                grid-template-columns: 1.15fr 1fr;
                gap: 80px;
                align-items: center;
            }

            @media (max-width: 900px) {
                .founder-inner-alt {
                    grid-template-columns: 1fr;
                    gap: 40px;
                }
                .founder-inner-alt .founder-image-wrap {
                    order: -1;
                }
            }

            .founder-inner-alt .founder-image-wrap {
                max-width: 380px;
            }

            /* ── SECTION 2: WHO WE ARE ── */
            .whoweare-section {
                padding: 96px 24px;
                background: #fff;
            }

            .whoweare-inner {
                max-width: 1100px;
                margin: 0 auto;
                text-align: center;
            }
            .whoweare-inner h2 {
                font-size: 2.6rem;
                color: var(--navy);
                margin-bottom: 1.25rem;
            }
            .whoweare-inner h2 span {
                color: var(--sky);
            }
            .whoweare-inner > p {
                font-size: 1.05rem;
                color: var(--gray);
                max-width: 760px;
                margin: 0 auto 3.5rem;
                line-height: 1.85;
            }

            .pillars-grid {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 24px;
                max-width: 840px;
                margin: 0 auto;
            }

            .pillar-card {
                padding: 32px 28px;
                background: var(--light);
                border-radius: 20px;
                text-align: left;
                border: 1px solid #e5e7eb;
                transition:
                    box-shadow 0.3s,
                    transform 0.3s;
                display: flex;
                gap: 18px;
                align-items: flex-start;
            }

            .pillar-card:hover {
                box-shadow: 0 8px 32px rgba(0, 191, 255, 0.15);
                transform: translateY(-3px);
            }

            .pillar-icon {
                width: 44px;
                height: 44px;
                min-width: 44px;
                border-radius: 12px;
                background: rgba(0, 191, 255, 0.1);
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .pillar-icon svg {
                width: 22px;
                height: 22px;
                color: var(--sky);
                stroke: var(--sky);
            }
            .pillar-card h4 {
                font-size: 1rem;
                font-family: "Inter", sans-serif;
                font-weight: 600;
                color: var(--navy);
                margin-bottom: 4px;
            }
            .pillar-card p {
                font-size: 0.88rem;
                color: var(--gray);
                line-height: 1.6;
            }

            /* ── SECTION 3: WHY CHOOSE US ── */
            .whychoose-section {
                padding: 96px 24px;
                background: var(--light);
            }

            .whychoose-inner {
                max-width: 1100px;
                margin: 0 auto;
                text-align: center;
            }
            .whychoose-inner h2 {
                font-size: 2.6rem;
                color: var(--navy);
                margin-bottom: 1.25rem;
            }
            .whychoose-inner h2 span {
                color: var(--sky);
            }
            .whychoose-inner > p {
                font-size: 1.05rem;
                color: var(--gray);
                max-width: 820px;
                margin: 0 auto 3.5rem;
                line-height: 1.85;
            }

            .reasons-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 28px;
            }

            .reason-card {
                padding: 36px 24px 28px;
                background: #fff;
                border-radius: 22px;
                text-align: center;
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
                transition:
                    box-shadow 0.3s,
                    transform 0.3s;
                border: 1px solid #f0f0f0;
            }

            .reason-card:hover {
                box-shadow: 0 10px 36px rgba(0, 191, 255, 0.18);
                transform: translateY(-4px);
            }

            .reason-img {
                width: 130px;
                height: 130px;
                border-radius: 50%;
                margin: 0 auto 1.25rem;
                overflow: hidden;
                background: #f0f4ff;
                display: flex;
                align-items: center;
                justify-content: center;
                border: 2px dashed #d1d5db;
            }

            .reason-img img {
                width: 100%;
                height: 100%;
                object-fit: contain;
            }
            .reason-img-placeholder {
                font-size: 0.7rem;
                color: #9ca3af;
                text-align: center;
                padding: 8px;
            }
            .reason-card h3 {
                font-size: 1.05rem;
                font-family: "Inter", sans-serif;
                font-weight: 600;
                color: var(--sky);
                line-height: 1.4;
            }

            .reason-row-2 {
                display: flex;
                justify-content: center;
                gap: 28px;
                margin-top: 28px;
            }
            .reason-row-2 .reason-card {
                width: calc(33.33% - 10px);
            }

            /* ── SECTION 4: VISION & MISSION ── */
            .vision-section {
                padding: 96px 24px;
                background: #fff;
            }

            .vision-inner {
                max-width: 1100px;
                margin: 0 auto;
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 72px;
                align-items: center;
            }

            .vision-content h2 {
                font-size: 2.6rem;
                color: var(--navy);
                margin-bottom: 2.5rem;
                line-height: 1.2;
            }
            .vision-content h2 span {
                color: var(--sky);
            }

            .vm-block {
                margin-bottom: 2rem;
                padding: 28px 24px;
                border-radius: 18px;
                background: var(--light);
                border-left: 5px solid var(--sky);
                transition: box-shadow 0.3s;
            }

            .vm-block.mission {
                border-left-color: var(--gold);
            }
            .vm-block:hover {
                box-shadow: 0 6px 24px rgba(0, 0, 0, 0.07);
            }

            .vm-label {
                font-size: 0.72rem;
                font-weight: 700;
                letter-spacing: 0.12em;
                text-transform: uppercase;
                color: var(--sky);
                font-family: "Inter", sans-serif;
                margin-bottom: 0.75rem;
            }
            .mission .vm-label {
                color: var(--gold);
            }
            .vm-block p {
                font-size: 1rem;
                color: var(--gray);
                line-height: 1.8;
            }

            .vision-image-placeholder {
                width: 100%;
                aspect-ratio: 4/3;
                border-radius: 24px;
                background: #e5e7eb;
                border: 2px dashed #d1d5db;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                color: #9ca3af;
                gap: 10px;
            }

            .vision-image-placeholder svg {
                width: 52px;
                height: 52px;
                color: #d1d5db;
            }
            .vision-image-placeholder span {
                font-size: 0.85rem;
                font-weight: 500;
            }

            /* ── SECTION 5: ADVISORS ── */
            .advisors-section {
                padding: 96px 24px;
                background: var(--navy);
                overflow: hidden;
            }

            .advisors-section .badge {
                background: rgba(255, 255, 255, 0.1);
                color: #93c5fd;
            }

            .advisors-inner {
                max-width: 1100px;
                margin: 0 auto;
                text-align: center;
            }
            .advisors-inner h2 {
                font-size: 2.6rem;
                color: #fff;
                margin-bottom: 1rem;
            }
            .advisors-inner h2 span {
                color: var(--sky);
            }
            .advisors-inner > p {
                font-size: 1.05rem;
                color: #94a3b8;
                max-width: 700px;
                margin: 0 auto 3rem;
                line-height: 1.8;
            }

            .carousel-track {
                overflow: hidden;
            }
            .carousel-slides {
                display: flex;
                transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            }

            .advisor-slide {
                min-width: 100%;
                display: flex;
                justify-content: center;
                padding: 0 16px;
            }

            /* ── Advisor Card (compact desktop) ── */
            .advisor-card {
                background: rgba(255, 255, 255, 0.05);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 20px;
                padding: 24px 28px;
                max-width: 660px;
                width: 100%;
                display: grid;
                grid-template-columns: 130px 1fr;
                gap: 24px;
                align-items: start;
                text-align: left;
                backdrop-filter: blur(8px);
            }

            .advisor-photo {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 10px;
            }

            .advisor-photo-img {
                width: 100px;
                height: 100px;
                border-radius: 50%;
                background: rgba(255, 255, 255, 0.08);
                border: 2px dashed rgba(255, 255, 255, 0.25);
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                color: rgba(255, 255, 255, 0.4);
                font-size: 0.6rem;
                gap: 4px;
                overflow: hidden;
            }

            .advisor-photo-img svg {
                width: 28px;
                height: 28px;
                opacity: 0.4;
            }
            .advisor-photo-img img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

            .advisor-name {
                font-size: 0.85rem;
                font-family: "Playfair Display", serif;
                color: #fff;
                text-align: center;
                line-height: 1.4;
            }
            .advisor-creds {
                font-size: 0.7rem;
                color: var(--sky);
                text-align: center;
                font-weight: 500;
                line-height: 1.4;
            }

            .advisor-info h3 {
                font-size: 1.15rem;
                color: #fff;
                margin-bottom: 0.3rem;
                line-height: 1.3;
            }
            .advisor-info .creds-line {
                font-size: 0.78rem;
                color: var(--sky);
                font-weight: 600;
                margin-bottom: 0.9rem;
                font-family: "Inter", sans-serif;
            }
            .advisor-info p {
                font-size: 0.82rem;
                color: #cbd5e1;
                line-height: 1.75;
                margin-bottom: 0.9rem;
            }

            .roles-heading {
                font-size: 0.68rem;
                font-weight: 700;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: var(--gold);
                font-family: "Inter", sans-serif;
                margin-bottom: 7px;
            }

            .advisor-roles {
                display: flex;
                flex-direction: column;
                gap: 6px;
            }
            .advisor-role-item {
                font-size: 0.78rem;
                color: #e2e8f0;
                line-height: 1.5;
                border-left: 3px solid var(--gold);
                padding-left: 10px;
            }

            /* Carousel controls */
            .carousel-controls {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 24px;
                margin-top: 2.5rem;
            }

            .carousel-btn {
                width: 44px;
                height: 44px;
                border-radius: 50%;
                background: rgba(255, 255, 255, 0.08);
                border: 1px solid rgba(255, 255, 255, 0.15);
                color: #fff;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                transition:
                    background 0.2s,
                    border-color 0.2s;
            }

            .carousel-btn:hover {
                background: var(--sky);
                border-color: var(--sky);
            }
            .carousel-btn svg {
                width: 18px;
                height: 18px;
                stroke: currentColor;
            }

            .carousel-dots {
                display: flex;
                gap: 8px;
                align-items: center;
            }

            .carousel-dot {
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: rgba(255, 255, 255, 0.25);
                cursor: pointer;
                transition:
                    background 0.2s,
                    width 0.2s;
                border: none;
            }

            .carousel-dot.active {
                background: var(--sky);
                width: 24px;
                border-radius: 4px;
            }

            /* ── RESPONSIVE ── */
            @media (max-width: 900px) {
                .founder-inner,
                .vision-inner {
                    grid-template-columns: 1fr;
                    gap: 40px;
                }

                .founder-image-wrap {
                    order: -1;
                }

                .reasons-grid {
                    grid-template-columns: 1fr 1fr;
                }
                .reason-row-2 {
                    flex-wrap: wrap;
                }
                .reason-row-2 .reason-card {
                    width: calc(50% - 14px);
                }
                .pillars-grid {
                    grid-template-columns: 1fr;
                }
            }

            @media (max-width: 640px) {
                .founder-content h2,
                .whoweare-inner h2,
                .whychoose-inner h2,
                .vision-content h2,
                .advisors-inner h2 {
                    font-size: 1.85rem;
                }

                .reasons-grid {
                    grid-template-columns: 1fr;
                }
                .reason-row-2 {
                    flex-direction: column;
                    align-items: center;
                }
                .reason-row-2 .reason-card {
                    width: 100%;
                }

                /* Advisor card: stack vertically on mobile */
                .advisor-card {
                    grid-template-columns: 1fr;
                    text-align: center;
                    padding: 20px 16px;
                    gap: 16px;
                    max-width: 100%;
                }

                .advisor-photo {
                    align-items: center;
                }

                .advisor-photo-img {
                    width: 80px;
                    height: 80px;
                    margin: 0 auto;
                }

                .advisor-info {
                    text-align: left;
                }
                .advisor-role-item {
                    text-align: left;
                }
                .advisor-slide {
                    padding: 0 4px;
                }

                .advisor-info h3 {
                    font-size: 1rem;
                    text-align: center;
                }
                .advisor-info .creds-line {
                    text-align: center;
                }
            }
        </style>
    </head>

    <body>
        <Navbar client:load />

        <!-- SECTION 1: MEET OUR FOUNDER -->
        <section class="founder-section">
            <div class="founder-inner">
                <div class="founder-image-wrap">
                    <div class="founder-accent"></div>
                    <div class="founder-accent-2"></div>
                    <div class="founder-image-placeholder">
                        <div class="placeholder-bg-icons">
                            <svg
                                style="top: 10%; left: 10%; width: 60px; height: 60px;"
                                viewBox="0 0 24 24"
                                ><path
                                    d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"
                                ></path></svg
                            >
                            <svg
                                style="bottom: 20%; right: 10%; width: 80px; height: 80px;"
                                viewBox="0 0 24 24"
                                ><path
                                    d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                                ></path></svg
                            >
                            <svg
                                style="top: 40%; right: 15%; width: 40px; height: 40px;"
                                viewBox="0 0 24 24"
                                ><path
                                    d="M12 3L1 9l11 6 9-4.91V17h2V9L12 3zM5 13.18v2.81l7 3.82 7-3.82v-2.81l-7 3.82-7-3.82z"
                                ></path></svg
                            >
                        </div>
                        <Image
                            src={mdImg}
                            alt="Mr. Feroz H.S - Founder & CEO"
                            loading="eager"
                        />
                        <div class="founder-name-card">
                            <div>
                                <strong>Mr. FEROZ H.S</strong>
                                <span>Founder &amp; CEO, Doctor Destiny</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="founder-content">
                    <div class="badge">MEET OUR FOUNDER</div>
                    <h2>Mr. Feroz <span>H.S</span></h2>
                    <p>
                        Mr. Feroz H.S, the visionary founder and CEO of Doctor
                        Destiny, has been the driving force behind our success.
                        With a profound dedication to education and a passion
                        for helping students achieve their dreams, Mr. Feroz has
                        built Doctor Destiny into a leading consultancy for
                        medical education abroad.
                    </p>
                    <br />
                    <p>
                        His expertise, leadership, and unwavering commitment to
                        excellence have transformed the lives of countless
                        students, guiding them on their path to becoming
                        successful medical professionals.
                    </p>
                </div>
            </div>
        </section>

        <!-- SECTION 1b: SECOND FOUNDER -->
        <section class="founder-section-alt">
            <div class="founder-inner-alt">
                <!-- Left: Content -->
                <div class="founder-content">
                    <div class="badge">MEET OUR CO-FOUNDER</div>
                    <h2>Mr. Afreed <span>H.S</span></h2>
                    <p>
                        Mr. Afreed H.S, Co-Founder and Director of Operations
                        at Doctor Destiny, brings a wealth of expertise in
                        student counselling and international education
                        management. With a deep understanding of the challenges
                        faced by aspiring medical students, he has been
                        instrumental in shaping the consultancy's student-first
                        philosophy.
                    </p>
                    <br />
                    <p>
                        His compassionate approach, meticulous attention to
                        detail, and hands-on experience in managing university
                        partnerships across Russia, Georgia, Nepal, and
                        Kyrgyzstan have made him the backbone of Doctor
                        Destiny's operational excellence. He ensures every
                        student's journey — from counselling to landing abroad —
                        is smooth, transparent, and successful.
                    </p>
                </div>

                <!-- Right: Photo -->
                <div class="founder-image-wrap">
                    <div class="founder-accent"></div>
                    <div class="founder-accent-2"></div>
                    <div class="founder-image-placeholder">
                        <div class="placeholder-bg-icons">
                            <svg
                                style="top: 10%; left: 10%; width: 60px; height: 60px;"
                                viewBox="0 0 24 24"
                                ><path
                                    d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"
                                ></path></svg
                            >
                            <svg
                                style="bottom: 20%; right: 10%; width: 80px; height: 80px;"
                                viewBox="0 0 24 24"
