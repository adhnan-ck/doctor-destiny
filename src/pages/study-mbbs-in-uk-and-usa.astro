---
import "../styles/global.css";
import "flag-icons/css/flag-icons.min.css";
import Navbar from "../components/Navbar.jsx";
import CountryLayout from "../components/CountryLayout.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&display=swap"
            rel="stylesheet"
        />
        <meta
            name="description"
            content="Study MBBS in the UK & USA – Complete guide including top universities, USMLE/PLAB details, clinical rotations, and admission procedures for Indian students."
        />
        <title>
            Study MBBS in UK & USA for Indian Students | Doctor Destiny
        </title>
    </head>
    <body class="bg-[#F0F7FF] overflow-x-hidden">
        <Navbar client:load />

        <!-- Page Hero -->
        <div class="bg-[#0E0C4F] pt-28 pb-16 px-6">
            <div class="max-w-5xl mx-auto text-center">
                <span
                    class="inline-block py-1 px-4 rounded-full bg-white/10 text-[#D5AD36] text-sm font-bold mb-4 tracking-widest uppercase"
                >
                    Study Abroad
                </span>
                <h1
                    class="text-4xl md:text-6xl font-extrabold text-white leading-tight mb-4"
                >
                    Study Medicine in <span class="text-[#00BFFF]"
                        >UK & USA</span
                    >
                </h1>
                <p
                    class="text-lg text-gray-300 max-w-3xl mx-auto leading-relaxed"
                >
                    Pursuing medicine in the United States or the United Kingdom
                    represents the pinnacle of global medical education.
                    Experience cutting-edge research, prestigious clinical
                    rotations, and unmatched career prospects worldwide.
                </p>
                <div class="mt-8">
                    <button
                        class="bg-gradient-to-r from-[#D5AD36] to-[#f0c847] hover:shadow-[0_0_20px_rgba(213,173,54,0.6)] text-[#0E0C4F] px-8 py-3 rounded-full font-bold transition-all duration-300 hover:scale-105"
                    >
                        Enroll Now
                    </button>
                </div>
            </div>
        </div>

        <!-- Country Layout (3-column) -->
        <CountryLayout
            countryName="UK & USA"
            navItems={[
                { label: "Overview & Duration", id: "overview-duration" },
                { label: "USA: The Pathway (BS+MD)", id: "usa-pathway" },
                { label: "UK: The Pathway (MBChB)", id: "uk-pathway" },
                { label: "Global Recognition", id: "recognition" },
                { label: "Eligibility Criteria", id: "eligibility" },
                { label: "Top Universities", id: "universities" },
                { label: "Why UK/USA?", id: "benefits" },
                { label: "Financials & ROI", id: "financials" },
            ]}
            faqs={[
                {
                    question: "Can I do MBBS directly after 12th in the USA?",
                    answer: "No, the USA follows a post-graduate medical system. You must first complete a 4-year Pre-Medical Bachelor's degree (BS) before entering a 4-year MD program.",
                },
                {
                    question: "Can I do MBBS directly after 12th in the UK?",
                    answer: "Yes, the UK offers undergraduate medical programs (usually MBChB or MBBS) extending for 5 to 6 years straight out of high school.",
                },
                {
                    question: "What is USMLE?",
                    answer: "The United States Medical Licensing Examination (USMLE) is a multi-part professional exam that allows medical graduates to practice in the USA.",
                },
                {
                    question: "What is PLAB / UKMLA?",
                    answer: "PLAB (Professional and Linguistic Assessments Board) is the standard test for international graduates to practice in the UK, which is transitioning into the UKMLA.",
                },
                {
                    question:
                        "Are medical degrees from UK/USA recognized in India?",
                    answer: "Yes, they are highly recognized by the NMC. In fact, graduates from certain top-tier countries like the USA and UK may even be exempt from the FMGE screening test to practice in India.",
                },
            ]}
        >
            <!-- SECTION: Overview -->
            <section id="overview-duration" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    Overview: The Ultimate Medical Destinations
                </h2>
                <div
                    class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 mb-6"
                >
                    <p class="text-gray-700 leading-relaxed">
                        Studying medicine in the <strong
                            >United States of America</strong
                        > or the <strong>United Kingdom</strong> is a rigorous, highly
                        competitive, but exceptionally rewarding journey. Both nations
                        host the world's most prestigious healthcare systems, advanced
                        research facilities, and highest-paid residency positions.
                        However, their pathways to becoming a doctor differ significantly.
                    </p>
                </div>

                <div class="grid md:grid-cols-2 gap-6">
                    <div
                        class="bg-blue-50/50 p-6 rounded-2xl border border-blue-100"
                    >
                        <h3
                            class="flex items-center gap-2 font-bold text-[#0E0C4F] mb-3"
                        >
                            <span class="text-[#00BFFF]">🇺🇸</span> Duration in USA
                        </h3>
                        <p class="text-gray-600 mb-2">
                            Total typical duration: <strong>7 to 8 Years</strong
                            >.
                        </p>
                        <ul
                            class="space-y-2 text-sm text-gray-700 list-disc list-inside"
                        >
                            <li>3-4 years Pre-Medical Degree (B.S.).</li>
                            <li>4 years Doctor of Medicine (M.D.) degree.</li>
                            <li>
                                Followed by 3-7 years of Residency depending on
                                the specialty.
                            </li>
                        </ul>
                    </div>
                    <div
                        class="bg-red-50/50 p-6 rounded-2xl border border-red-100"
                    >
                        <h3
                            class="flex items-center gap-2 font-bold text-[#0E0C4F] mb-3"
                        >
                            <span class="text-red-500">🇬🇧</span> Duration in UK
                        </h3>
                        <p class="text-gray-600 mb-2">
                            Total typical duration: <strong>5 to 6 Years</strong
                            >.
                        </p>
                        <ul
                            class="space-y-2 text-sm text-gray-700 list-disc list-inside"
                        >
                            <li>
                                Direct admission post-high school (12th grade).
                            </li>
                            <li>
                                5-6 years of academic and clinical training
                                combined (MBBS / MBChB).
                            </li>
                            <li>
                                Followed by a 2-year Foundation Programme (FY1 &
                                FY2).
                            </li>
                        </ul>
                    </div>
                </div>
            </section>

            <!-- SECTION: USA Pathway -->
            <section id="usa-pathway" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    USA: The Pre-Med to MD Pathway
                </h2>
                <div class="space-y-4">
                    <div
                        class="flex gap-4 p-5 bg-white rounded-xl shadow-sm border border-gray-100"
                    >
                        <span
                            class="flex-shrink-0 w-10 h-10 rounded-full bg-[#0E0C4F] text-white flex items-center justify-center font-bold"
                            >1</span
                        >
                        <div>
                            <h4 class="font-bold text-[#0E0C4F]">
                                Pre-Medical Degree (B.S.) Target
                            </h4>
                            <p class="text-sm text-gray-600 mt-1">
                                Students must complete a Bachelor's degree
                                (often in Biology, Chemistry, or Pre-Med)
                                emphasizing heavy science prerequisites. This
                                serves as the foundation before entering real
                                medical school.
                            </p>
                        </div>
                    </div>
                    <div
                        class="flex gap-4 p-5 bg-white rounded-xl shadow-sm border border-gray-100"
                    >
                        <span
                            class="flex-shrink-0 w-10 h-10 rounded-full bg-[#00BFFF] text-white flex items-center justify-center font-bold"
                            >2</span
                        >
                        <div>
                            <h4 class="font-bold text-[#0E0C4F]">
                                The MCAT Examination
                            </h4>
                            <p class="text-sm text-gray-600 mt-1">
                                During the final years of the BS degree,
                                students must take the incredibly competitive
                                Medical College Admission Test (MCAT) to qualify
                                for MD programs.
                            </p>
                        </div>
                    </div>
                    <div
                        class="flex gap-4 p-5 bg-white rounded-xl shadow-sm border border-gray-100"
                    >
                        <span
                            class="flex-shrink-0 w-10 h-10 rounded-full bg-[#D5AD36] text-white flex items-center justify-center font-bold"
                            >3</span
                        >
                        <div>
                            <h4 class="font-bold text-[#0E0C4F]">
                                Doctor of Medicine (M.D.) & USMLE
                            </h4>
                            <p class="text-sm text-gray-600 mt-1">
                                4 years of highly intensive medical school.
                                Students undertake USMLE Step 1 and Step 2 exams
                                during this period to qualify for prestigious
                                Residency matches in the USA.
                            </p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- SECTION: UK Pathway -->
            <section id="uk-pathway" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    UK: The Undergraduate Pathway
                </h2>
                <div class="space-y-4">
                    <div
                        class="flex gap-4 p-5 bg-white rounded-xl shadow-sm border border-gray-100"
                    >
                        <span
                            class="flex-shrink-0 w-10 h-10 rounded-full bg-[#0E0C4F] text-white flex items-center justify-center font-bold"
                            >1</span
                        >
                        <div>
                            <h4 class="font-bold text-[#0E0C4F]">
                                Direct Entry & Examinations
                            </h4>
                            <p class="text-sm text-gray-600 mt-1">
                                After 12th grade (A-Levels / IB equivalent),
                                international students apply through UCAS and
                                must crack the UCAT or BMAT specific aptitude
                                tests.
                            </p>
                        </div>
                    </div>
                    <div
                        class="flex gap-4 p-5 bg-white rounded-xl shadow-sm border border-gray-100"
                    >
                        <span
                            class="flex-shrink-0 w-10 h-10 rounded-full bg-red-500 text-white flex items-center justify-center font-bold"
                            >2</span
                        >
                        <div>
                            <h4 class="font-bold text-[#0E0C4F]">
                                MBBS / MBChB Program
                            </h4>
                            <p class="text-sm text-gray-600 mt-1">
                                A rigorous 5 to 6-year course integrating
                                pre-clinical theoretical science with clinical
                                ward rotations in NHS (National Health Service)
                                affiliated hospitals.
                            </p>
                        </div>
                    </div>
                    <div
                        class="flex gap-4 p-5 bg-white rounded-xl shadow-sm border border-gray-100"
                    >
                        <span
                            class="flex-shrink-0 w-10 h-10 rounded-full bg-[#D5AD36] text-white flex items-center justify-center font-bold"
                            >3</span
                        >
                        <div>
                            <h4 class="font-bold text-[#0E0C4F]">
                                Foundation Programme (FY1 & FY2)
                            </h4>
                            <p class="text-sm text-gray-600 mt-1">
                                Post-graduation, junior doctors complete a
                                2-year paid clinical training period under the
                                NHS before choosing a specialty (General
                                Practice, Surgery, etc.).
                            </p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- SECTION: Recognition -->
            <section id="recognition" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    Unrivaled Global Recognition
                </h2>
                <div class="bg-[#0E0C4F] text-white p-6 rounded-2xl">
                    <p class="mb-4 text-gray-300">
                        Degrees from the UK and USA hold the absolute highest
                        tier of recognition globally. Graduates are highly
                        sought after worldwide.
                    </p>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        {
                            [
                                "General Medical Council (GMC, UK)",
                                "ACGME & LCME (USA)",
                                "National Medical Commission (NMC, India)",
                                "World Health Organization (WHO)",
                                "FAIMER & ECFMG Approved",
                                "Medical Board of California (Global Standard)",
                            ].map((org) => (
                                <div class="bg-white/10 p-3 rounded-lg text-sm text-center font-medium border border-white/20">
                                    {org}
                                </div>
                            ))
                        }
                    </div>
                </div>
            </section>

            <!-- SECTION: Universities -->
            <section id="universities" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    Prestigious Universities
                </h2>
                <div class="grid lg:grid-cols-2 gap-8">
                    <!-- USA -->
                    <div
                        class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm"
                    >
                        <div
                            class="bg-blue-900 text-white font-bold p-4 flex items-center justify-between"
                        >
                            <span>Top Universities in USA</span>
                            <span>🇺🇸</span>
                        </div>
                        <ul class="divide-y divide-gray-100">
                            {
                                [
                                    "Harvard Medical School",
                                    "Johns Hopkins University",
                                    "Stanford University School of Medicine",
                                    "University of California, San Francisco (UCSF)",
                                    "Yale School of Medicine",
                                    "Columbia University",
                                ].map((uni) => (
                                    <li class="p-3 text-sm text-gray-700 font-medium hover:bg-gray-50">
                                        {uni}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                    <!-- UK -->
                    <div
                        class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm"
                    >
                        <div
                            class="bg-red-900 text-white font-bold p-4 flex items-center justify-between"
                        >
                            <span>Top Universities in UK</span>
                            <span>🇬🇧</span>
                        </div>
                        <ul class="divide-y divide-gray-100">
                            {
                                [
                                    "University of Oxford",
                                    "University of Cambridge",
                                    "University College London (UCL)",
                                    "Imperial College London",
                                    "King's College London",
                                    "University of Edinburgh",
                                ].map((uni) => (
                                    <li class="p-3 text-sm text-gray-700 font-medium hover:bg-gray-50">
                                        {uni}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                </div>
            </section>

            <!-- SECTION: Why UK/USA -->
            <section id="benefits" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    Why Choose the UK or USA?
                </h2>
                <div class="grid md:grid-cols-3 gap-6">
                    <div
                        class="bg-white border top-2 border-gray-100 p-6 rounded-2xl shadow-sm hover:shadow-md transition"
                    >
                        <span class="text-3xl mb-3 block">🔬</span>
                        <h4 class="font-bold text-[#0E0C4F] mb-2">
                            Pioneering Research
                        </h4>
                        <p class="text-sm text-gray-600">
                            Access to the world's finest medical laboratories,
                            newest technological advancements, and Nobel
                            laureate faculties.
                        </p>
                    </div>
                    <div
                        class="bg-white border top-2 border-gray-100 p-6 rounded-2xl shadow-sm hover:shadow-md transition"
                    >
                        <span class="text-3xl mb-3 block">🩺</span>
                        <h4 class="font-bold text-[#0E0C4F] mb-2">
                            Peak Clinical Exposure
                        </h4>
                        <p class="text-sm text-gray-600">
                            Rotations in legendary institutions (like the Mayo
                            Clinic or NHS Trusts) observing rare cases globally.
                        </p>
                    </div>
                    <div
                        class="bg-white border top-2 border-gray-100 p-6 rounded-2xl shadow-sm hover:shadow-md transition"
                    >
                        <span class="text-3xl mb-3 block">🌟</span>
                        <h4 class="font-bold text-[#0E0C4F] mb-2">
                            Ultimate Career ROI
                        </h4>
                        <p class="text-sm text-gray-600">
                            Doctors in the US and UK command the highest
                            salaries globally, offsetting the high initial
                            educational investments quickly.
                        </p>
                    </div>
                </div>
            </section>

            <!-- SECTION: Financials -->
            <section id="financials" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    Financials & Scholarships
                </h2>
                <div
                    class="bg-orange-50/50 border border-orange-100 p-6 rounded-2xl"
                >
                    <h3
                        class="font-bold text-orange-900 mb-4 flex items-center gap-2"
                    >
                        <span>💰</span> Investment Overview
                    </h3>
                    <p class="text-sm text-gray-700 leading-relaxed mb-4">
                        Studying medicine in these premium tier-1 nations
                        requires a significant financial investment.
                        <strong>USA programs</strong> can range from $250,000 to $400,000+
                        over the entire course.
                        <strong>UK programs</strong> typically range from £35,000
                        to £50,000+ per year for international students.
                    </p>
                    <ul
                        class="text-sm text-gray-800 space-y-2 list-disc list-inside bg-white p-4 rounded-xl border border-orange-200"
                    >
                        <li>
                            <strong>Paid Residencies:</strong> In the US, Residents
                            earn salaries ranging from $50,000 to $70,000+ while completing
                            post-grad. In the UK, FY1/FY2 doctors earn starting salaries
                            around £30,000+.
                        </li>
                        <li>
                            <strong>Scholarships:</strong> Highly competitive but
                            available (e.g., Chevening in the UK, university-specific
                            grants in the US) for exceptional academic performers.
                        </li>
                        <li>
                            <strong>Loans:</strong> Robust banking support is available
                            for students securing admissions into these elite universities.
                        </li>
                    </ul>
                </div>
            </section>
        </CountryLayout>

        <Footer />
    </body>
</html>
