---
import "../styles/global.css";
import "flag-icons/css/flag-icons.min.css";
import Navbar from "../components/Navbar.jsx";
import CountryLayout from "../components/CountryLayout.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&display=swap"
            rel="stylesheet"
        />
        <meta
            name="description"
            content="Study MBBS in Georgia — Affordable fees, globally recognized universities, and expert guidance from Doctor Destiny."
        />
        <title>Study MBBS in Georgia | Doctor Destiny</title>
    </head>
    <body class="bg-[#F0F7FF] overflow-x-hidden">
        <Navbar client:load />

        <!-- Page Hero -->
        <div class="bg-[#0E0C4F] pt-28 pb-16 px-6">
            <div class="max-w-5xl mx-auto text-center">
                <span
                    class="inline-block py-1 px-4 rounded-full bg-white/10 text-[#D5AD36] text-sm font-bold mb-4 tracking-widest uppercase"
                >
                    Study Abroad
                </span>
                <h1
                    class="text-4xl md:text-6xl font-extrabold text-white leading-tight mb-4"
                >
                    Study MBBS in <span class="text-[#00BFFF]">Georgia</span>
                </h1>
                <p
                    class="text-lg text-gray-300 max-w-2xl mx-auto leading-relaxed"
                >
                    Georgia has emerged as one of the most popular destinations
                    for Indian students aspiring to pursue MBBS abroad with
                    affordable tuition and globally recognized medical
                    universities.
                </p>
            </div>
        </div>

        <CountryLayout
            countryName="Georgia"
            navItems={[
                { label: "MBBS Duration", id: "duration" },
                { label: "Top Universities", id: "universities" },
                { label: "Tuition Fees", id: "fees" },
                { label: "Fee Structure (Govt)", id: "fee-structure" },
                { label: "Syllabus & Curriculum", id: "curriculum" },
                { label: "Admission Process", id: "admission" },
                { label: "Documents Required", id: "documents" },
                { label: "Why Georgia?", id: "benefits" },
                { label: "Loan Assistance", id: "loans" },
                { label: "Career & PG Options", id: "career" },
                { label: "Safety & Housing", id: "safety" },
                { label: "NEET Requirement", id: "neet" },
            ]}
            faqs={[
                {
                    question:
                        "Is MBBS in Georgia recognized by NMC (formerly MCI)?",
                    answer: "Yes, Georgian medical universities are recognized by NMC, WHO, and other international bodies. Graduates are eligible for FMGE/NEXT in India.",
                },
                {
                    question:
                        "What is the medium of instruction for MBBS in Georgia?",
                    answer: "The medium of instruction is English, making it convenient for Indian students without requiring additional language courses.",
                },
                {
                    question:
                        "What is the total cost of studying MBBS in Georgia?",
                    answer: "The total cost ranges from ₹20-35 Lakhs for the 6-year program. Living expenses are roughly $200-$350 monthly.",
                },
                {
                    question: "Is NEET required for studying MBBS in Georgia?",
                    answer: "Yes, qualifying NEET is mandatory for Indian students intending to practice in India after graduation.",
                },
                {
                    question:
                        "What are the living conditions for students in Georgia?",
                    answer: "Universities offer modern hostels, and the country is exceptionally safe. Indian food is widely available in major cities.",
                },
                {
                    question:
                        "Can I practice in India after completing MBBS from Georgia?",
                    answer: "Yes, you can practice in India after clearing the FMGE/NEXT screening test conducted by the NMC.",
                },
            ]}
        >
            <!-- SECTION: Duration -->
            <section id="duration" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    MBBS Duration in Georgia
                </h2>
                <div class="grid md:grid-cols-2 gap-6 items-center">
                    <div>
                        <p class="text-gray-600 leading-relaxed mb-4">
                            The MBBS program in Georgia spans <strong
                                >6 years</strong
                            > (12 semesters). The first 5 years focus on academic
                            instruction and clinical theory, followed by a mandatory
                            1-year clinical internship.
                        </p>
                        <ul class="space-y-3">
                            <li class="flex items-center gap-3 text-gray-700">
                                <span class="w-2 h-2 rounded-full bg-[#00BFFF]"
                                ></span>
                                5 Years: Pre-clinical & Clinical Study
                            </li>
                            <li class="flex items-center gap-3 text-gray-700">
                                <span class="w-2 h-2 rounded-full bg-[#00BFFF]"
                                ></span>
                                1 Year: Mandatory Internship
                            </li>
                        </ul>
                    </div>
                    <div
                        class="bg-blue-50/50 p-6 rounded-2xl border border-blue-100"
                    >
                        <h4 class="font-bold text-[#0E0C4F] mb-2">
                            Subject Coverage:
                        </h4>
                        <p class="text-sm text-gray-600">
                            Physiology, Pathology, Pharmacology, Microbiology,
                            Surgery, OB-GYN, and Pediatrics.
                        </p>
                    </div>
                </div>
            </section>

            <!-- SECTION: Universities -->
            <section id="universities" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    Top Medical Universities in Georgia
                </h2>
                <p class="text-gray-600 leading-relaxed mb-5">
                    Georgia hosts prestigious medical universities recognized by <strong
                        >WHO, NMC, ECFMG</strong
                    >, and other global bodies.
                </p>
                <div
                    class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm mb-6"
                >
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-[#0E0C4F] text-white text-sm">
                                <th class="px-5 py-3.5 font-semibold"
                                    >Establishment</th
                                >
                                <th class="px-5 py-3.5 font-semibold"
                                    >Location</th
                                >
                                <th class="px-5 py-3.5 font-semibold"
                                    >University Name</th
                                >
                            </tr>
                        </thead>
                        <tbody class="text-gray-700 text-sm">
                            {
                                [
                                    {
                                        year: "2004",
                                        place: "Tbilisi",
                                        name: "SEU Georgian National University",
                                    },
                                    {
                                        year: "1998",
                                        place: "Georgia",
                                        name: "Geomedi Medical University",
                                    },
                                    {
                                        year: "1930",
                                        place: "Georgia",
                                        name: "Akaki Tsereteli Medical State University",
                                    },
                                    {
                                        year: "1945",
                                        place: "Batumi",
                                        name: "Batumi Shota Rustaveli State University",
                                    },
                                    {
                                        year: "1918",
                                        place: "Tbilisi",
                                        name: "Tbilisi State Medical University",
                                    },
                                    {
                                        year: "1785",
                                        place: "Tbilisi",
                                        name: "University of Georgia",
                                    },
                                    {
                                        year: "1992",
                                        place: "Tbilisi",
                                        name: "Tbilisi Medical Academy (TMA)",
                                    },
                                ].map((uni, index) => (
                                    <tr
                                        class={`border-b border-gray-100 ${index % 2 === 0 ? "bg-white" : "bg-gray-50/50"}`}
                                    >
                                        <td class="px-5 py-4">{uni.year}</td>
                                        <td class="px-5 py-4">{uni.place}</td>
                                        <td class="px-5 py-4 font-medium text-[#0E0C4F]">
                                            {uni.name}
                                        </td>
                                    </tr>
                                ))
                            }
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- SECTION: Fees -->
            <section id="fees" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    MBBS Tuition Fees & Expenses
                </h2>
                <p class="text-gray-600 mb-6">
                    Georgia offers high-quality medical education at a fraction
                    of the cost compared to the USA, UK, or even private
                    colleges in India.
                </p>

                <div class="grid md:grid-cols-3 gap-6 mb-8">
                    {
                        [
                            {
                                name: "Geomedi Medical University",
                                year: "$5,500",
                                total: "₹27,40,000",
                            },
                            {
                                name: "Akaki Tsereteli State Univ.",
                                year: "$4,500",
                                total: "₹22,41,000",
                            },
                            {
                                name: "Batumi Shota Rustaveli State",
                                year: "$4,000",
                                total: "₹19,92,000",
                            },
                        ].map((fee) => (
                            <div class="bg-white p-5 rounded-2xl border border-gray-100 shadow-sm hover:border-[#00BFFF] transition-colors">
                                <h4 class="font-bold text-[#0E0C4F] h-12 flex items-center mb-2">
                                    {fee.name}
                                </h4>
                                <div class="space-y-1">
                                    <p class="text-sm text-gray-500">
                                        Per Year
                                    </p>
                                    <p class="text-2xl font-bold text-[#00BFFF]">
                                        {fee.year}
                                    </p>
                                </div>
                                <div class="mt-4 pt-4 border-t border-gray-50">
                                    <p class="text-[12px] uppercase tracking-wider text-gray-400 font-bold">
                                        Total Budget
                                    </p>
                                    <p class="text-lg font-semibold text-gray-700">
                                        {fee.total}
                                    </p>
                                </div>
                            </div>
                        ))
                    }
                </div>

                <div class="bg-[#0E0C4F] text-white p-6 rounded-2xl">
                    <h4 class="font-bold mb-3 flex items-center gap-2">
                        <span class="text-[#D5AD36]">ℹ</span> Additional Cost Considerations
                    </h4>
                    <ul class="grid md:grid-cols-2 gap-4 text-sm text-gray-300">
                        <li class="flex gap-2">
                            <span class="text-[#00BFFF] font-bold">•</span>
                            <span
                                >Food expenses are estimated at <strong
                                    >$150/month</strong
                                >.</span
                            >
                        </li>
                        <li class="flex gap-2">
                            <span class="text-[#00BFFF] font-bold">•</span>
                            <span
                                >Living costs are approx. 2.5x lower than
                                Western Europe.</span
                            >
                        </li>
                    </ul>
                </div>
            </section>

            <!-- SECTION: Fee Structure Govt -->
            <section id="fee-structure" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    Government University Fee Structure
                </h2>
                <div
                    class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100"
                >
                    <p class="text-gray-600 mb-4">
                        Government universities in Georgia are prestigious and
                        offer competitive tuition fees for international
                        students.
                    </p>
                    <div class="flex flex-wrap gap-4 items-center">
                        <div
                            class="px-6 py-3 bg-blue-50 rounded-xl border border-blue-100"
                        >
                            <p class="text-sm text-gray-500 font-medium">
                                Annual Tuition
                            </p>
                            <p class="text-xl font-bold text-[#0E0C4F]">
                                $4,000 - $5,000
                            </p>
                        </div>
                        <div
                            class="px-6 py-3 bg-yellow-50 rounded-xl border border-yellow-100"
                        >
                            <p class="text-sm text-gray-500 font-medium">
                                Approx. in INR
                            </p>
                            <p class="text-xl font-bold text-[#b4912d]">
                                ₹3.3 - 5 Lakhs
                            </p>
                        </div>
                    </div>
                    <ul
                        class="mt-6 space-y-2 text-gray-600 text-sm list-disc list-inside"
                    >
                        <li>
                            High-quality education with excellent campus
                            facilities
                        </li>
                        <li>Favorable student-teacher ratio</li>
                        <li>
                            Modern healthcare facilities for hands-on learning
                        </li>
                        <li>Simple and efficient admission process</li>
                    </ul>
                </div>
            </section>

            <!-- SECTION: Curriculum -->
            <section id="curriculum" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    MBBS Syllabus & Curriculum
                </h2>
                <div
                    class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm"
                >
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-[#0E0C4F] text-white text-sm">
                                <th class="px-5 py-3.5 font-semibold"
                                    >Semester</th
                                >
                                <th class="px-5 py-3.5 font-semibold"
                                    >Core Subjects</th
                                >
                            </tr>
                        </thead>
                        <tbody class="text-gray-700 text-sm">
                            {
                                [
                                    {
                                        sem: "1st",
                                        sub: "Medical Terminology, Genetics, Language, Anatomy Part I",
                                    },
                                    {
                                        sem: "2nd",
                                        sub: "Laboratory Chemistry, Medical History, Language",
                                    },
                                    {
                                        sem: "3rd",
                                        sub: "Physiology Part 2, Anatomy Part 3, Microbiology Part I, Biochemistry Part 2, Bioethics, Clinical Skills",
                                    },
                                    {
                                        sem: "4th",
                                        sub: "Pathology, Microbiology Part 2, Physiology Part 3, Behavioral Physiology, Pharmacology Part 1",
                                    },
                                    {
                                        sem: "5th",
                                        sub: "Systemic Pathology Part 1, Pharmacology Part 2, Behavioral Science, Clinical Skills, Surgery Part I",
                                    },
                                    {
                                        sem: "6th",
                                        sub: "Surgery Part 2, Systemic Pathology, Radiology",
                                    },
                                    {
                                        sem: "7th",
                                        sub: "Psychiatry, Professional Pathologies, Neurology",
                                    },
                                    {
                                        sem: "8th",
                                        sub: "Obstetrics, Surgery, Infectious Diseases, Electrocardiogram",
                                    },
                                    {
                                        sem: "9th",
                                        sub: "Dermatovenerology, Gynecology, Surgery, Nutrition, Traumatology",
                                    },
                                    {
                                        sem: "10th",
                                        sub: "Pediatric Surgery, Clinical Pharmacology",
                                    },
                                    {
                                        sem: "11th",
                                        sub: "Pharmacotherapy, Plastic Surgery, Oncology, Tuberculosis",
                                    },
                                    {
                                        sem: "12th",
                                        sub: "Internal Medicine, Surgery, Obstetrics, Critical Care, Ethics, Law, Toxicology",
                                    },
                                ].map((item, index) => (
                                    <tr
                                        class={`border-b border-gray-100 ${index % 2 === 0 ? "bg-white" : "bg-gray-50/50"}`}
                                    >
                                        <td class="px-5 py-4 font-bold text-[#0E0C4F]">
                                            {item.sem}
                                        </td>
                                        <td class="px-5 py-4 text-gray-600">
                                            {item.sub}
                                        </td>
                                    </tr>
                                ))
                            }
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- SECTION: Admission -->
            <section id="admission" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    Admission Process & Timeline
                </h2>
                <div class="grid md:grid-cols-2 gap-8">
                    <div>
                        <h4 class="font-bold text-[#0E0C4F] mb-4">
                            Step-by-Step Enrollment:
                        </h4>
                        <div class="space-y-4">
                            {
                                [
                                    {
                                        step: "1",
                                        title: "Apply Online",
                                        desc: "Submit application form with academic documents.",
                                    },
                                    {
                                        step: "2",
                                        title: "Offer Letter",
                                        desc: "Receive admission confirmation from university.",
                                    },
                                    {
                                        step: "3",
                                        title: "Fee Payment",
                                        desc: "Pay first-year tuition directly to the university.",
                                    },
                                    {
                                        step: "4",
                                        title: "Visa Processing",
                                        desc: "Ministry of Education approval & Embassy visa.",
                                    },
                                    {
                                        step: "5",
                                        title: "Departure",
                                        desc: "Document preparation and travel to Georgia.",
                                    },
                                ].map((s) => (
                                    <div class="flex gap-4">
                                        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-[#00BFFF] text-white flex items-center justify-center font-bold">
                                            {s.step}
                                        </span>
                                        <div>
                                            <p class="font-bold text-gray-800">
                                                {s.title}
                                            </p>
                                            <p class="text-sm text-gray-600">
                                                {s.desc}
                                            </p>
                                        </div>
                                    </div>
                                ))
                            }
                        </div>
                    </div>
                    <div>
                        <h4 class="font-bold text-[#0E0C4F] mb-4">
                            Session Timeline:
                        </h4>
                        <div
                            class="overflow-x-auto rounded-xl border border-gray-200"
                        >
                            <table
                                class="w-full text-left border-collapse text-sm"
                            >
                                <thead class="bg-gray-100 text-gray-600">
                                    <tr>
                                        <th class="px-4 py-2">Month</th>
                                        <th class="px-4 py-2">Process</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {
                                        [
                                            {
                                                m: "April - May",
                                                p: "Registration Starts",
                                            },
                                            {
                                                m: "May - June",
                                                p: "Document Qualification",
                                            },
                                            {
                                                m: "June - July",
                                                p: "Acceptance Letter",
                                            },
                                            {
                                                m: "July - Aug",
                                                p: "Invitation Letter",
                                            },
                                            {
                                                m: "September",
                                                p: "Visa & Departure",
                                            },
                                            {
                                                m: "Oct - Dec",
                                                p: "Enrollment & Classes",
                                            },
                                        ].map((t) => (
                                            <tr class="border-b border-gray-50">
                                                <td class="px-4 py-2 font-medium">
                                                    {t.m}
                                                </td>
                                                <td class="px-4 py-2 text-gray-600">
                                                    {t.p}
                                                </td>
                                            </tr>
                                        ))
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </section>

            <!-- SECTION: Documents -->
            <section id="documents" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    Documents Required for Visa
                </h2>
                <div
                    class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm"
                >
                    <ul class="grid md:grid-cols-2 gap-y-3 gap-x-8">
                        {
                            [
                                "10th & 12th Marksheets",
                                "NEET Scorecard",
                                "Digitized Passport Sized Photos",
                                "Official Invitation Letter",
                                "Rector's Directive",
                                "Birth Certificate",
                                "Original Passport",
                                "Letter of Sponsorship",
                                "NOC Certificate",
                                "Travel Insurance",
                                "Latest Bank Statements",
                            ].map((doc) => (
                                <li class="flex items-center gap-3 text-gray-600">
                                    <span class="text-[#00BFFF]">✔</span> {doc}
                                </li>
                            ))
                        }
                    </ul>
                    <div
                        class="mt-6 p-4 bg-orange-50 rounded-xl border border-orange-100"
                    >
                        <p class="text-xs text-orange-800 font-medium">
                            Note: Prepare documents at least 1 month in advance
                            as embassy processing usually takes over 30 days.
                        </p>
                    </div>
                </div>
            </section>

            <!-- SECTION: Benefits -->
            <section id="benefits" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    Why Study MBBS in Georgia?
                </h2>
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {
                        [
                            {
                                title: "Global Recognition",
                                desc: "Accredited by WHO, NMC, and FAIMER.",
                            },
                            {
                                title: "English Medium",
                                desc: "No IELTS/TOEFL required. Courses are 100% in English.",
                            },
                            {
                                title: "Affordable Living",
                                desc: "Living costs are significantly lower than USA/UK/Europe.",
                            },
                            {
                                title: "Safe Environment",
                                desc: "Georgia is in the top 10 safest countries globally.",
                            },
                            {
                                title: "No Donation",
                                desc: "Direct admissions based on merit with no hidden fees.",
                            },
                            {
                                title: "Practical Exposure",
                                desc: "Emphasis on hands-on learning in modern hospitals.",
                            },
                        ].map((b) => (
                            <div class="p-5 rounded-2xl bg-white border border-gray-100 shadow-sm">
                                <h4 class="font-bold text-[#0E0C4F] mb-2">
                                    {b.title}
                                </h4>
                                <p class="text-sm text-gray-600">{b.desc}</p>
                            </div>
                        ))
                    }
                </div>
            </section>

            <!-- SECTION: Loan Assistance -->
            <section id="loans" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    Education Loan Assistance
                </h2>
                <div
                    class="bg-gradient-to-br from-[#0E0C4F] to-[#252374] p-8 rounded-2xl text-white shadow-lg"
                >
                    <h3 class="text-xl font-bold mb-4 text-[#D5AD36]">
                        Fueling Your Dreams
                    </h3>
                    <p class="text-gray-300 mb-6">
                        We provide full support to Indian students seeking
                        education loans for their MBBS in Georgia.
                    </p>
                    <div class="grid md:grid-cols-2 gap-4">
                        {
                            [
                                "Guidance on bank documentation",
                                "Connections with private & national banks",
                                "Assistance in lower interest rates",
                                "Form filling & liaison support",
                                "Seamless hassle-free processing",
                            ].map((item) => (
                                <div class="flex gap-2 items-start text-sm">
                                    <span class="text-[#00BFFF]">✦</span>
                                    <span class="text-gray-200">{item}</span>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </section>

            <!-- SECTION: Career & PG Options -->
            <section id="career" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    Career Scope & PG Options
                </h2>
                <p class="text-gray-600 mb-6 font-medium">
                    Graduates from Georgian medical universities have a wide
                    horizon of global opportunities:
                </p>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    {
                        [
                            { title: "USA", desc: "Qualify USMLE" },
                            { title: "UK", desc: "Clear PLAB" },
                            { title: "India", desc: "Clear NMC (FMGE/NEXT)" },
                            { title: "Australia", desc: "Pass AMC Exams" },
                            { title: "Germany", desc: "Join PG Program" },
                            { title: "Europe", desc: "Language & License" },
                            { title: "Admin", desc: "Hospital Mgmt" },
                            { title: "Private", desc: "Open Clinic" },
                        ].map((o) => (
                            <div class="bg-white p-4 rounded-xl border border-gray-100 text-center">
                                <h5 class="text-[#00BFFF] font-extrabold uppercase tracking-widest text-[10px] mb-1">
                                    {o.title}
                                </h5>
                                <p class="text-sm font-bold text-gray-700">
                                    {o.desc}
                                </p>
                            </div>
                        ))
                    }
                </div>
            </section>

            <!-- SECTION: Safety & Housing -->
            <section id="safety" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    Safety & Accommodation
                </h2>
                <div class="grid md:grid-cols-2 gap-8">
                    <div class="space-y-4">
                        <div
                            class="bg-green-50/50 p-5 rounded-2xl border border-green-100"
                        >
                            <h4 class="font-bold text-green-900 mb-2">
                                Safety Overview
                            </h4>
                            <p class="text-sm text-green-800">
                                Georgia is known for its hospitality and low
                                crime rate. Visible police patrols and friendly
                                locals ensure a secure environment for Indian
                                students.
                            </p>
                        </div>
                        <ul
                            class="text-sm text-gray-600 space-y-2 list-disc list-inside"
                        >
                            <li>Visible night police presence</li>
                            <li>Welcoming and hospitable culture</li>
                            <li>
                                Separate hostels for male and female students
                            </li>
                        </ul>
                    </div>
                    <div
                        class="bg-gray-50 p-5 rounded-2xl border border-gray-200"
                    >
                        <h4 class="font-bold text-[#0E0C4F] mb-3">
                            Housing Options
                        </h4>
                        <div class="space-y-3">
                            <div>
                                <p class="text-sm font-bold text-gray-800">
                                    University Hostels
                                </p>
                                <p class="text-xs text-gray-500">
                                    Modern, shared or private rooms with
                                    amenities.
                                </p>
                            </div>
                            <div>
                                <p class="text-sm font-bold text-gray-800">
                                    Private Apartments
                                </p>
                                <p class="text-xs text-gray-500">
                                    For students with higher budgets, usually in
                                    city centers.
                                </p>
                            </div>
                            <div>
                                <p class="text-sm font-bold text-gray-800">
                                    Home Stays
                                </p>
                                <p class="text-xs text-gray-500">
                                    Living with local families for cultural
                                    immersion.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- SECTION: NEET -->
            <section id="neet" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    NEET Requirement for Georgia
                </h2>
                <div class="bg-red-50 p-6 rounded-2xl border border-red-100">
                    <p class="text-gray-800 font-medium mb-4">
                        Per NMC regulations, qualifying NEET is mandatory for
                        Indian students intending to practice in India after
                        MBBS abroad.
                    </p>
                    <div class="grid md:grid-cols-2 gap-6">
                        <div class="p-4 bg-white rounded-xl shadow-sm">
                            <h5 class="text-red-600 font-bold mb-1">
                                With NEET
                            </h5>
                            <p class="text-xs text-gray-600 leading-relaxed">
                                Eligible to clear FMGE/NEXT in India and
                                practice as a registered doctor.
                            </p>
                        </div>
                        <div class="p-4 bg-white rounded-xl shadow-sm">
                            <h5 class="text-gray-600 font-bold mb-1">
                                Without NEET
                            </h5>
                            <p class="text-xs text-gray-600 leading-relaxed">
                                Can still study in Georgia but ineligible to
                                practice in India. Careers restricted to Georgia
                                or other nations.
                            </p>
                        </div>
                    </div>
                </div>
            </section>
        </CountryLayout>

        <Footer />
    </body>
</html>
