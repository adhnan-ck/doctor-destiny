---
import { Image } from "astro:assets";
import Navbar from "../components/Navbar";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

// 1. Fetch images dynamically mapping through the glob
const imagesGlob = import.meta.glob<{ default: ImageMetadata }>('../assets/gallery/*.{jpeg,jpg,png,gif}');

// 2. Resolve the image metadata promises
const images = await Promise.all(
  Object.keys(imagesGlob).map(async (key) => {
    const resolvedImage = await imagesGlob[key]();
    return resolvedImage.default;
  })
);
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Gallery – Doctor Destiny</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600&display=swap"
            rel="stylesheet"
        />
        <style>
            body {
                font-family: "Inter", sans-serif;
                background-color: #fff;
                margin: 0;
            }
            .gallery-hero {
                background: #e8f4fc;
                padding: 90px 24px 48px;
                text-align: center;
                position: relative;
                overflow: hidden;
            }
            .hero-label {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 14px;
                margin-bottom: 1.25rem;
            }
            .hero-label-line {
                flex: 1;
                max-width: 80px;
                height: 2px;
                background: #d5ad36;
                border-radius: 2px;
            }
            .hero-label span {
                font-size: 0.95rem;
                font-weight: 700;
                color: #d5ad36;
                letter-spacing: 0.05em;
                text-transform: uppercase;
                font-family: "Inter", sans-serif;
            }
            .gallery-hero h1 {
                font-family: "Playfair Display", serif;
                font-size: clamp(2.2rem, 4vw, 3.2rem);
                color: #0e0c4f;
                line-height: 1.25;
                font-weight: 700;
                max-width: 640px;
                margin: 0 auto 1.25rem auto;
            }
            .gallery-hero p {
                font-size: 1.05rem;
                color: #6b7280;
                max-width: 600px;
                margin: 0 auto;
                line-height: 1.6;
            }
        </style>
    </head>
    <body class="min-h-screen flex flex-col">
        <Navbar client:load />

        <main class="flex-grow">
            <!-- Hero Banner -->
            <section class="gallery-hero">
                <div class="hero-label">
                    <div class="hero-label-line"></div>
                    <span>Visual Journey</span>
                    <div class="hero-label-line"></div>
                </div>
                <h1>Our Gallery</h1>
                <!-- <p>
                    Take a glimpse into the vibrant campus life, modern facilities, 
                    and the incredible journey of our students studying medicine abroad.
                </p> -->
            </section>

            <!-- Justified Grid Gallery using CSS Grid & Tailwind -->
            <!-- We use 'grid-cols-...' combined with 'aspect-square' and 'object-cover' to maintain clean aligned boxes without JS masonry libraries -->
            <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6 lg:gap-8">
                    {images.map((img, index) => (
                        <div class="relative group overflow-hidden rounded-xl shadow-sm bg-gray-100 aspect-square">
                            <Image 
                                src={img} 
                                alt={`Gallery image ${index + 1}`} 
                                class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-110 group-hover:brightness-110"
                                loading={index < 4 ? "eager" : "lazy"}
                            />
                            <!-- Subtle fade overlay on hover -->
                            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-500 pointer-events-none"></div>
                        </div>
                    ))}
                </div>
            </section>
        </main>

        <Footer />
    </body>
</html>
