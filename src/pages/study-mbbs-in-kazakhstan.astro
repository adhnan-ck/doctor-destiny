---
import "../styles/global.css";
import "flag-icons/css/flag-icons.min.css";
import Navbar from "../components/Navbar.jsx";
import CountryLayout from "../components/CountryLayout.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&display=swap"
            rel="stylesheet"
        />
        <meta
            name="description"
            content="Study MBBS in Kazakhstan – Complete guide including top MCI listed universities, duration, and benefits for Indian students."
        />
        <title>
            MBBS in Kazakhstan for Indian Students: Admissions and Universities
            | Doctor Destiny
        </title>
    </head>
    <body class="bg-[#F0F7FF] overflow-x-hidden">
        <Navbar client:load />

        <!-- Page Hero -->
        <div class="bg-[#0E0C4F] pt-28 pb-16 px-6">
            <div class="max-w-5xl mx-auto text-center">
                <span
                    class="inline-block py-1 px-4 rounded-full bg-white/10 text-[#D5AD36] text-sm font-bold mb-4 tracking-widest uppercase"
                >
                    Study Abroad
                </span>
                <h1
                    class="text-4xl md:text-6xl font-extrabold text-white leading-tight mb-4"
                >
                    Study MBBS in <span class="text-[#00BFFF]">Kazakhstan</span>
                </h1>
                <p
                    class="text-lg text-gray-300 max-w-3xl mx-auto leading-relaxed"
                >
                    Pursue your MBBS in Kazakhstan, a prime destination for
                    Indian medical aspirants offering affordable fees,
                    English-medium instruction, and world-class MCI listed
                    government universities.
                </p>
                <div class="mt-8">
                    <button
                        class="bg-gradient-to-r from-[#D5AD36] to-[#f0c847] hover:shadow-[0_0_20px_rgba(213,173,54,0.6)] text-[#0E0C4F] px-8 py-3 rounded-full font-bold transition-all duration-300 hover:scale-105"
                    >
                        Enroll Now
                    </button>
                </div>
            </div>
        </div>

        <!-- Country Layout (3-column) -->
        <CountryLayout
            countryName="Kazakhstan"
            navItems={[
                { label: "Duration & Medium", id: "duration-medium" },
                { label: "Recognition", id: "recognition" },
                { label: "Eligibility Criteria", id: "eligibility" },
                { label: "Why Kazakhstan?", id: "benefits" },
                { label: "MCI Govt. Universities", id: "universities-fees" },
                { label: "Explore Kazakhstan", id: "explore" },
            ]}
            faqs={[
                {
                    question: "How long is the MBBS course in Kazakhstan?",
                    answer: "The MBBS program in Kazakhstan has a duration of exactly 5 years.",
                },
                {
                    question: "What is the medium of instruction?",
                    answer: "The entire course is taught in English, which makes it perfect for international students.",
                },
                {
                    question: "Is NEET mandatory for Indian students?",
                    answer: "Yes, a valid NEET score is required if you wish to practice medicine in India after graduation.",
                },
                {
                    question:
                        "How long is the flight from India to Kazakhstan?",
                    answer: "There are direct flights from New Delhi to Almaty that take around 4 to 5 hours.",
                },
            ]}
        >
            <!-- SECTION: Duration & Medium -->
            <section id="duration-medium" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    Duration & Medium of Study
                </h2>
                <div class="grid md:grid-cols-2 gap-6">
                    <div
                        class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100"
                    >
                        <h3
                            class="flex items-center gap-2 font-bold text-[#0E0C4F] mb-3"
                        >
                            <span class="text-[#00BFFF]">⏱</span> Course Duration
                        </h3>
                        <p class="text-gray-600 mb-3">
                            The total duration for an MBBS program in Kazakhstan
                            is <strong>5 Years</strong>.
                        </p>
                        <ul
                            class="space-y-2 text-sm text-gray-600 list-disc list-inside"
                        >
                            <li>Comprehensive classroom training.</li>
                            <li>
                                Extensive clinical rotations to match global
                                medical standards.
                            </li>
                        </ul>
                    </div>
                    <div
                        class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100"
                    >
                        <h3
                            class="flex items-center gap-2 font-bold text-[#0E0C4F] mb-3"
                        >
                            <span class="text-[#00BFFF]">🗣</span> Medium of Study
                        </h3>
                        <p class="text-gray-600 leading-relaxed text-sm mb-3">
                            MBBS in Kazakhstan is taught 100% in <strong
                                >English</strong
                            >. With English being a primary medium of
                            instruction across medical universities,
                            international students face absolutely no
                            communication barrier regarding academics.
                        </p>
                    </div>
                </div>
            </section>

            <!-- SECTION: Recognition -->
            <section id="recognition" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    Recognition of Universities
                </h2>
                <div class="bg-[#0E0C4F] text-white p-6 rounded-2xl">
                    <p class="mb-4 text-gray-300">
                        Medical colleges in Kazakhstan hold prominent
                        international accreditations, allowing graduates to
                        practice seamlessly worldwide:
                    </p>
                    <div
                        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"
                    >
                        {
                            [
                                "National Medical Commission (NMC/MCI)",
                                "World Health Organization (WHO)",
                                "Educational Commission for Foreign Medical Graduates (ECFMG)",
                                "Foundation for Advancement of International Medical Education and Research (FAIMER)",
                            ].map((org) => (
                                <div class="bg-white/10 p-3 rounded-lg text-sm text-center font-medium border border-white/20 flex flex-col items-center justify-center">
                                    {org}
                                </div>
                            ))
                        }
                    </div>
                </div>
            </section>

            <!-- SECTION: Eligibility -->
            <section id="eligibility" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    Eligibility Criteria
                </h2>
                <div
                    class="mb-6 bg-blue-50/50 p-6 rounded-xl border border-blue-100"
                >
                    <ul class="grid md:grid-cols-2 gap-4 text-sm text-gray-700">
                        <li
                            class="flex gap-3 items-start p-3 bg-white rounded-xl shadow-sm border border-gray-100"
                        >
                            <span class="text-[#00BFFF] text-lg">✔</span>
                            <span
                                ><strong>Academic Requirement:</strong> Minimum 50%
                                aggregate in Physics, Chemistry, and Biology (PCB)
                                in 12th standard.</span
                            >
                        </li>
                        <li
                            class="flex gap-3 items-start p-3 bg-white rounded-xl shadow-sm border border-gray-100"
                        >
                            <span class="text-[#00BFFF] text-lg">✔</span>
                            <span
                                ><strong>NEET Examination:</strong> Indian students
                                must qualify for NEET to be eligible for admission
                                and practice in India later.</span
                            >
                        </li>
                        <li
                            class="flex gap-3 items-start p-3 bg-white rounded-xl shadow-sm border border-gray-100"
                        >
                            <span class="text-[#00BFFF] text-lg">✔</span>
                            <span
                                ><strong>Age Limit:</strong> Must be at least 17 years
                                old at the time of admission.</span
                            >
                        </li>
                    </ul>
                </div>
            </section>

            <!-- SECTION: Why Kazakhstan -->
            <section id="benefits" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    Why Study MBBS in Kazakhstan?
                </h2>
                <div
                    class="bg-white p-6 rounded-2xl border border-gray-200 shadow-sm"
                >
                    <p class="text-gray-700 leading-relaxed mb-4">
                        Studying MBBS in Kazakhstan is a fantastic choice for
                        medical aspirants, especially from India, due to deep
                        cultural ties, exceptional educational infrastructure,
                        and a comfortable lifestyle.
                    </p>
                    <ul
                        class="space-y-3 text-sm text-gray-700 list-disc list-inside"
                    >
                        <li>
                            <strong>Safe & Peaceful:</strong> One of the safest nations
                            in Central Asia with a low crime rate and welcoming locals.
                        </li>
                        <li>
                            <strong>Close to India:</strong> Extremely close geographically;
                            a direct flight from New Delhi to Almaty takes only 4
                            to 5 hours.
                        </li>
                        <li>
                            <strong>Familiar Atmosphere:</strong> High Indian student
                            population means you will easily find Indian cuisine and
                            familiar cultural practices.
                        </li>
                        <li>
                            <strong>High NMC Passing Rate:</strong> The syllabus highly
                            aligns with the Indian medical structure, giving graduates
                            a steep advantage in FMGE exams.
                        </li>
                        <li>
                            <strong>Affordable & High Quality:</strong> The fee structures
                            provide great value for the high caliber of education
                            imparted.
                        </li>
                    </ul>
                </div>
            </section>

            <!-- SECTION: Fees & Universities -->
            <section id="universities-fees" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    MCI Listed Govt. Universities
                </h2>
                <div
                    class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm mb-6"
                >
                    <table
                        class="w-full text-left border-collapse min-w-[500px]"
                    >
                        <thead>
                            <tr class="bg-[#0E0C4F] text-white text-sm">
                                <th
                                    class="px-4 py-3 font-semibold w-16 text-center"
                                    >SR NO.</th
                                >
                                <th class="px-4 py-3 font-semibold"
                                    >University Name</th
                                >
                                <th class="px-4 py-3 font-semibold">Location</th
                                >
                            </tr>
                        </thead>
                        <tbody class="text-gray-700 text-sm">
                            <tr class="border-b border-gray-100 bg-white">
                                <td class="px-4 py-4 text-center font-bold"
                                    >1</td
                                >
                                <td class="px-4 py-4 font-bold text-[#0E0C4F]"
                                    >Kazakh National Medical University</td
                                >
                                <td class="px-4 py-4">Almaty</td>
                            </tr>
                            <tr class="border-b border-gray-100 bg-gray-50/50">
                                <td class="px-4 py-4 text-center font-bold"
                                    >2</td
                                >
                                <td class="px-4 py-4 font-bold text-[#0E0C4F]"
                                    >Astana Medical University</td
                                >
                                <td class="px-4 py-4">Almaty</td>
                            </tr>
                            <tr class="border-b border-gray-100 bg-white">
                                <td class="px-4 py-4 text-center font-bold"
                                    >3</td
                                >
                                <td class="px-4 py-4 font-bold text-[#0E0C4F]"
                                    >Al-Farabi Kazakh National University</td
                                >
                                <td class="px-4 py-4">Almaty</td>
                            </tr>
                            <tr class="border-b border-gray-100 bg-gray-50/50">
                                <td class="px-4 py-4 text-center font-bold"
                                    >4</td
                                >
                                <td class="px-4 py-4 font-bold text-[#0E0C4F]"
                                    >Kazakh Medical Uni. For Continuing Edu.</td
                                >
                                <td class="px-4 py-4">Almaty</td>
                            </tr>
                            <tr class="border-b border-gray-100 bg-white">
                                <td class="px-4 py-4 text-center font-bold"
                                    >5</td
                                >
                                <td class="px-4 py-4 font-bold text-[#0E0C4F]"
                                    >South Kazakhstan State University</td
                                >
                                <td class="px-4 py-4">Shymkent</td>
                            </tr>
                            <tr class="border-b border-gray-100 bg-gray-50/50">
                                <td class="px-4 py-4 text-center font-bold"
                                    >6</td
                                >
                                <td class="px-4 py-4 font-bold text-[#0E0C4F]"
                                    >North Kazakh State University</td
                                >
                                <td class="px-4 py-4">Petropavl</td>
                            </tr>
                            <tr class="border-b border-gray-100 bg-white">
                                <td class="px-4 py-4 text-center font-bold"
                                    >7</td
                                >
                                <td class="px-4 py-4 font-bold text-[#0E0C4F]"
                                    >West Kazakh State University</td
                                >
                                <td class="px-4 py-4">Aktobe</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- SECTION: Explore Kazakhstan -->
            <section id="explore" class="mb-12 scroll-mt-24">
                <h2
                    class="text-2xl md:text-3xl font-bold text-[#0E0C4F] mb-4 pb-3 border-b-2 border-[#00BFFF]/30"
                >
                    Let’s Explore Kazakhstan
                </h2>
                <div
                    class="bg-gradient-to-br from-[#0E0C4F] to-[#252374] p-8 rounded-2xl text-white shadow-lg flex flex-col md:flex-row gap-8 items-center"
                >
                    <div class="w-full md:w-1/2">
                        <h3 class="text-xl font-bold mb-4 text-[#D5AD36]">
                            The Heart of Central Asia
                        </h3>
                        <p class="text-sm text-gray-300 leading-relaxed mb-6">
                            Kazakhstan stands out with its diverse culture,
                            rapidly developing metropolitan cities, and strong
                            educational frameworks. It offers a unique blend of
                            a welcoming environment and strict safety standards.
                        </p>
                    </div>
                    <div
                        class="w-full md:w-1/2 bg-white/10 p-5 rounded-xl border border-white/20"
                    >
                        <ul class="text-sm grid grid-cols-2 gap-y-4 gap-x-4">
                            <li>
                                <span class="text-[#00BFFF]">Capital:</span> Nur-Sultan
                            </li>
                            <li>
                                <span class="text-[#00BFFF]">Currency:</span> Kazakhstani
                                Tenge
                            </li>
                            <li class="col-span-2">
                                <span class="text-[#00BFFF]"
                                    >Weather Range:</span
                                > Varied climate (-03°C to 30°C)
                            </li>
                            <li class="col-span-2">
                                <span class="text-[#00BFFF]"
                                    >Metropolitan Cities:</span
                                > Astana, Almaty
                            </li>
                            <li class="col-span-2">
                                <span class="text-[#00BFFF]"
                                    >Direct Flight:</span
                                > New Delhi to Almaty in 4-5 hours
                            </li>
                        </ul>
                    </div>
                </div>
            </section>
        </CountryLayout>

        <Footer />
    </body>
</html>
